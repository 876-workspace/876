# ─── Server-side (never exposed to the browser) ──────────────────────────────

# Base URL for server-side API calls.
API_URL=https://876-api.vercel.app

# Server log level for Next.js server logs.
LOG_LEVEL=info

# Shared secret for trusted server-to-server calls to the API (AdminDep).
# Must match API_INTERNAL_KEY set on the API deployment.
API_INTERNAL_KEY=

# Seals/unseals the iron-session cookie. Must be 32+ characters.
# Must be the same value as WORKOS_COOKIE_PASSWORD in the 876 app.
WORKOS_COOKIE_PASSWORD=

# Optional: override the session cookie name (default: 876-session).
# SESSION_COOKIE_NAME=876-session

# App API key for the console registered app (format: 876_app_secret_...). Used
# server-side by the /api/auth proxy and the admin client; never sent to the
# browser. Run apps/api/scripts/seed_internal.py to generate one for local dev.
API_876_KEY=

# Optional OAuth client ID override for the seeded "876-console" internal
# app. When omitted, Console discovers it from the app behind API_876_KEY.
CONSOLE_OAUTH_CLIENT_ID=

# Identity origin that owns /login and /oauth/*.
CONSOLE_IDENTITY_URL=https://876-app.vercel.app

# Optional callback override. Defaults to the current request origin in production
# and Codespaces, or `http://localhost:3002/oauth/callback` on a local machine.
# CONSOLE_OAUTH_REDIRECT_URI=https://876-misc.vercel.app/oauth/callback

# Optional seed-script helper; set this before running apps/api/scripts/seed_internal.py
# in deployed environments so it registers the correct callback URI.
# CONSOLE_URL=https://876-misc.vercel.app

# ─── Public (exposed to the browser via NEXT_PUBLIC_*) ───────────────────────

# URL of the consumer app (used for cross-app links).
NEXT_PUBLIC_CONSUMER_URL=https://876-app.vercel.app

# Canonical URL of Console itself.
NEXT_PUBLIC_CONSOLE_URL=https://876-misc.vercel.app

# Observability.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_APP_VERSION=
NEXT_PUBLIC_APP_ENVIRONMENT=production

# 876 Billing versioned admin surface (server-only `@876/billing/admin` client).
BILLING_API_URL=http://127.0.0.1:4004
BILLING_INTERNAL_KEY=

# Core 876 app slug for this app (public; defaults to the canonical slug in code).
NEXT_PUBLIC_876_APP_SLUG=console

# Copy these values to apps/console/.env. Never put WIDGETS_DATABASE_URL here.
WIDGETS_API_URL=http://127.0.0.1:3005
WIDGETS_SERVICE_KEY=replace-with-the-widgets-api-service-key
