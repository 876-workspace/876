# Local-machine development URLs (non-secret). In GitHub Codespaces, the OAuth
# routes derive the forwarded `*.app.github.dev` origins from the request/env and
# these localhost fallbacks are not used for browser redirects.
NEXT_PUBLIC_CONSUMER_URL=http://localhost:3000
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3002
API_URL=http://127.0.0.1:4000

# Optional override. When omitted, Console discovers its client_id from
# the API app associated with API_876_KEY.
CONSOLE_OAUTH_CLIENT_ID=
