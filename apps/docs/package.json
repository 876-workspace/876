{
  "name": "@876/docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack --port 3003",
    "prebuild": "pnpm --filter @876/sdk build",
    "build": "next build",
    "start": "next start --port 3003",
