    "clsx": "2.1.1",
    "tailwind-merge": "3.6.0",
    "fumadocs-core": "16.9.3",
    "fumadocs-openapi": "10.10.2",
    "fumadocs-ui": "16.9.3",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.3",
    "@tailwindcss/postcss": "4.3.0",
    "@types/mdx": "2.0.13",
    "@types/node": "25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "fumadocs-mdx": "15.0.10",
    "tailwindcss": "4.3.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
