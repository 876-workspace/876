# Core 876 application identity. This must match the app slug shown in Console.
NEXT_PUBLIC_876_APP_SLUG=876-couriers
# Display name shown on shared auth screens.
NEXT_PUBLIC_APP_NAME=876 Couriers

# Core API URLs. Keep the internal URL server-only.
API_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# App API key (876_app_secret_...) issued from Console > Apps > API Keys.
API_876_KEY=

# Internal key (x-internal-key), server-only. Couriers uses it ONLY for the
# privileged platform bootstrap client (@876/core/platform) — routing
# memberships, feature evaluation, app-subscription entitlements — never for
# admin CRUD. Must match the identity API's API_INTERNAL_KEY. Never expose to
# the browser.
API_INTERNAL_KEY=

# 876 Billing data-plane service URL (server-only).
BILLING_URL=http://127.0.0.1:3004

# This app's own public origin (used for absolute links). Couriers runs on port 3003.
NEXT_PUBLIC_COURIERS_URL=http://localhost:3003
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Couriers app-local database (Postgres/Neon). Server-only; this is a SEPARATE
# database from the 876 identity API — it stores only courier operational data.
DATABASE_URL=

# Session cookie seal secret. Must match the API's value exactly. The core
# unsealer accepts SESSION_COOKIE_SECRET first, then WORKOS_COOKIE_PASSWORD as a
# legacy fallback. Set one (min 32 chars in production).
SESSION_COOKIE_SECRET=
# WORKOS_COOKIE_PASSWORD=

# Optional session cookie name override (defaults to '876-session').
# SESSION_COOKIE_NAME=876-session

# Shared 876 ecosystem analytics project.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_APP_ENVIRONMENT=development

# Copy these values to apps/couriers/.env.local. Never put WIDGETS_DATABASE_URL here.
WIDGETS_API_URL=http://127.0.0.1:3005
WIDGETS_SERVICE_KEY=replace-with-the-widgets-api-service-key
