/// A staff position title within a tenant (e.g. "Branch Manager", "Delivery Driver", "Customer Service").
/// Positions are tenant-scoped — each organization defines their own operational hierarchy.
/// These are courier-app roles, distinct from 876 platform org roles (which govern platform access).
model StaffPosition {
  id        String  @id @default(cuid())
  tenantId  String  @map("tenant_id")
  name      String
  isActive  Boolean @default(true) @map("is_active")
  createdAt Int     @map("created_at")
  updatedAt Int     @map("updated_at")

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "staff_positions_tenant_id_fkey")
  members StaffMember[]

  @@unique([tenantId, name], name: "staff_positions_tenant_id_name_key", map: "staff_positions_tenant_id_name_key")
  @@index([tenantId], map: "staff_positions_tenant_id_idx")
  @@map("staff_positions")
}

/// A staff member employed by a tenant, optionally assigned to a branch and position.
/// userId is an opaque 876 user ID — identity details (name, email) resolved through $876 at read time.
/// A staff member may be unassigned to a branch (e.g. a head-office employee).
model StaffMember {
  id         String  @id @default(cuid())
  tenantId   String  @map("tenant_id")
  userId     String  @map("user_id")
  branchId   String? @map("branch_id")
  positionId String? @map("position_id")
  isActive   Boolean @default(true) @map("is_active")
  createdAt  Int     @map("created_at")
  updatedAt  Int     @map("updated_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "staff_members_tenant_id_fkey")
  branch       Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "staff_members_branch_id_fkey")
  position     StaffPosition? @relation(fields: [positionId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "staff_members_position_id_fkey")
  cashSessions CashSession[]

  @@unique([tenantId, userId], name: "staff_members_tenant_id_user_id_key", map: "staff_members_tenant_id_user_id_key")
  @@index([tenantId], map: "staff_members_tenant_id_idx")
  @@index([userId], map: "staff_members_user_id_idx")
  @@index([branchId], map: "staff_members_branch_id_idx")
  @@index([positionId], map: "staff_members_position_id_idx")
  @@map("staff_members")
}
