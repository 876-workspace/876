/// A tenant-owned Jamaica office / customer pickup location.
/// Customers are assigned a home branch at enrollment; packages are routed there by default.
/// isDefault marks the first/primary branch shown during onboarding and signup flows.
/// settings is a schemaless JSONB bag for future branch-level config (e.g. delivery options,
/// pickup hours) — structure is defined by the application layer, not enforced here.
model Branch {
  id        String  @id @default(cuid())
  tenantId  String  @map("tenant_id")
  name      String
  street1   String  @map("street_1")
  street2   String? @map("street_2")
  city      String
  parish    String?
  country   String  @default("JM")
  phone     String?
  isDefault Boolean @default(false) @map("is_default")
  isActive  Boolean @default(true) @map("is_active")
  /// Schemaless branch configuration. Structure defined by application layer.
  settings  Json?
  createdAt Int     @map("created_at")
  updatedAt Int     @map("updated_at")

  tenant    Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers CourierCustomerProfile[]
  packages  Package[]
  staff     StaffMember[]

  @@unique([tenantId, name], name: "branches_tenant_id_name_key")
  @@index([tenantId], name: "branches_tenant_id_idx")
  @@map("branches")
}
