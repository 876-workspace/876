# Billing's own PostgreSQL connection. Never commit a real value.
BILLING_DATABASE_URL=

# Core 876 URL and server-only credentials.
API_URL=http://127.0.0.1:4000
# Public issuer advertised to third-party Billing integrations.
BILLING_OAUTH_ISSUER=http://localhost:4000
API_INTERNAL_KEY=
# Must match the API's session-cookie signing secret.
SESSION_COOKIE_SECRET=
# Generated by apps/api/scripts/seed_internal.py for the 876-billing app.
BILLING_API_876_KEY=
SESSION_COOKIE_NAME=876-session

# Browser-facing Billing application URL.
NEXT_PUBLIC_BILLING_URL=http://localhost:3004

# Shared 876 ecosystem analytics project.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_APP_ENVIRONMENT=development

# Server-to-server key for the Console -> Billing internal admin surface
# (`/api/v1/admin/*`). Empty disables all internal admin requests.
BILLING_INTERNAL_KEY=
# Billing tenant that receives Console-mirrored platform records.
BILLING_PLATFORM_TENANT_SLUG=

# Core 876 app slug for this app (public; defaults to the canonical slug in code).
NEXT_PUBLIC_876_APP_SLUG=876-billing

# Copy these values to apps/billing/.env. Never put WIDGETS_DATABASE_URL here.
WIDGETS_API_URL=http://127.0.0.1:3005
WIDGETS_SERVICE_KEY=replace-with-the-widgets-api-service-key
