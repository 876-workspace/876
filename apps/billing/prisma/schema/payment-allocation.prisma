
/// The portion of one payment applied to one invoice.
model PaymentAllocation {
  id                  String        @id
  tenantId            String        @map("tenant_id")
  paymentId           String        @map("payment_id")
  invoiceId           String        @map("invoice_id")
  amount              BigInt
  invoiceStatusBefore InvoiceStatus @map("invoice_status_before")
  invoicePaidAtBefore Int?          @map("invoice_paid_at_before")
  reversedAt          Int?          @map("reversed_at")
  createdAt           Int           @map("created_at")
  updatedAt           Int           @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_payment_allocations_tenant_id_fkey")
  payment Payment @relation(fields: [tenantId, paymentId], references: [tenantId, id], onDelete: Cascade, onUpdate: Cascade, map: "billing_payment_allocations_payment_fkey")
  invoice Invoice @relation(fields: [tenantId, invoiceId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_payment_allocations_invoice_fkey")

  @@index([tenantId, paymentId], map: "billing_payment_allocations_tenant_payment_idx")
  @@index([tenantId, invoiceId], map: "billing_payment_allocations_tenant_invoice_idx")
  @@index([tenantId, paymentId, reversedAt], map: "billing_payment_allocations_active_idx")
  @@index([invoiceId], map: "billing_payment_allocations_invoice_id_idx")
  @@index([paymentId], map: "billing_payment_allocations_payment_id_idx")
  @@map("billing_payment_allocations")
}
