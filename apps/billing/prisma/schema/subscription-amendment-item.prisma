
model SubscriptionAmendmentItem {
  id          String  @id
  amendmentId String  @map("amendment_id")
  priceId     String  @map("price_id")
  position    Int     @default(0)
  quantity    Int     @default(1)
  unitAmount  BigInt? @map("unit_amount")
  currency    String? @db.Char(3)
  description String?
  createdAt   Int     @map("created_at")

  amendment SubscriptionAmendment @relation(fields: [amendmentId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_subscription_amendment_items_amendment_fkey")
  price     Price                 @relation(fields: [priceId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "billing_subscription_amendment_items_price_fkey")

  @@unique([amendmentId, position], name: "billing_subscription_amendment_items_position_key", map: "billing_subscription_amendment_items_position_key")
  @@index([priceId], map: "billing_subscription_amendment_items_price_idx")
  @@map("billing_subscription_amendment_items")
}
