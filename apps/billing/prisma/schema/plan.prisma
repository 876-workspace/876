/// A subscription plan defines its cadence, trial, setup-fee, and commercial
/// lifecycle. Prices are separate, immutable records so a plan can offer more
/// than one currency or pricing configuration without changing subscribers.
/// `entitlementReferenceId` is an optional opaque link to the core entitlement
/// record (a core product/plan-tier ID); one plan exists per core
/// plan-tier per billing cadence.
model Plan {
  id                     String       @id
  tenantId               String       @map("tenant_id")
  productId              String       @map("product_id")
  code                   String
  name                   String
  description            String?
  imageUrl               String?      @map("image_url")
  unitName               String?      @map("unit_name")
  taxCode                String?      @map("tax_code")
  entitlementReferenceId String?      @map("entitlement_reference_id")
  intervalUnit           IntervalUnit @map("interval_unit")
  intervalCount          Int          @default(1) @map("interval_count")
  billingCycleCount      Int?         @map("billing_cycle_count")
  trialDays              Int          @default(0) @map("trial_days")
  setupFeeAmount         BigInt?      @map("setup_fee_amount")
  setupFeeCurrency       String?      @map("setup_fee_currency")
  isTaxable              Boolean      @default(false) @map("is_taxable")
  isFree                 Boolean      @default(false) @map("is_free")
  showInCheckout         Boolean      @default(true) @map("show_in_checkout")
  isActive               Boolean      @default(true) @map("is_active")
  metadata               Json?
  createdAt              Int          @map("created_at")
  updatedAt              Int          @map("updated_at")

  tenant                Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product               Product                   @relation(fields: [productId], references: [id], onDelete: Restrict)
  prices                Price[]
  addonAssociations     PlanAddonAssociation[]
  couponApplicabilities CouponPlanApplicability[]
  fallbackForProducts   Product[]                 @relation("ProductFallbackPlan")

  @@unique([tenantId, code], name: "billing_plans_tenant_id_code_key")
  @@unique([tenantId, entitlementReferenceId, intervalUnit, intervalCount], name: "billing_plans_tenant_entitlement_cadence_key")
  @@index([tenantId], name: "billing_plans_tenant_id_idx")
  @@index([productId], name: "billing_plans_product_id_idx")
  @@index([entitlementReferenceId], name: "billing_plans_entitlement_reference_id_idx")
  @@map("billing_plans")
}
