
/// Normalized provider charge lifecycle. A successful attempt may create or
/// link a Payment, while failures never mutate invoice balances.
model PaymentAttempt {
  id                   String               @id
  tenantId             String               @map("tenant_id")
  connectionId         String?              @map("connection_id")
  customerId           String               @map("customer_id")
  invoiceId            String?              @map("invoice_id")
  subscriptionId       String?              @map("subscription_id")
  paymentId            String?              @map("payment_id")
  idempotencyKey       String               @map("idempotency_key")
  externalReference    String?              @map("external_reference")
  status               PaymentAttemptStatus @default(PROCESSING)
  amount               BigInt
  currency             String               @db.Char(3)
  failureCode          String?              @map("failure_code")
  failureMessage       String?              @map("failure_message")
  providerResponseCode String?              @map("provider_response_code")
  attemptedAt          Int                  @map("attempted_at")
  completedAt          Int?                 @map("completed_at")
  createdAt            Int                  @map("created_at")
  updatedAt            Int                  @map("updated_at")

  tenant       Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_payment_attempts_tenant_fkey")
  connection   PaymentProviderConnection? @relation(fields: [tenantId, connectionId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_payment_attempts_connection_fkey")
  customer     Customer                   @relation(fields: [tenantId, customerId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_payment_attempts_customer_fkey")
  invoice      Invoice?                   @relation(fields: [tenantId, invoiceId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_payment_attempts_invoice_fkey")
  subscription Subscription?              @relation(fields: [subscriptionId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "billing_payment_attempts_subscription_fkey")
  payment      Payment?                   @relation(fields: [tenantId, paymentId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_payment_attempts_payment_fkey")

  @@unique([tenantId, id], map: "billing_payment_attempts_tenant_id_id_key")
  @@unique([tenantId, idempotencyKey], map: "billing_payment_attempts_tenant_idempotency_key")
  @@unique([connectionId, externalReference], map: "billing_payment_attempts_connection_external_key")
  @@index([tenantId, status, attemptedAt], map: "billing_payment_attempts_tenant_status_date_idx")
  @@index([customerId], map: "billing_payment_attempts_customer_id_idx")
  @@index([invoiceId], map: "billing_payment_attempts_invoice_id_idx")
  @@index([paymentId], map: "billing_payment_attempts_payment_id_idx")
  @@index([subscriptionId], map: "billing_payment_attempts_subscription_id_idx")
  @@map("billing_payment_attempts")
}
