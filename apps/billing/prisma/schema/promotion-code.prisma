
/// Customer-facing redemption code separated from the discount definition.
model PromotionCode {
  id             String  @id
  tenantId       String  @map("tenant_id")
  couponId       String  @map("coupon_id")
  code           String
  customerId     String? @map("customer_id")
  expiresAt      Int?    @map("expires_at")
  maxRedemptions Int?    @map("max_redemptions")
  timesRedeemed  Int     @default(0) @map("times_redeemed")
  isActive       Boolean @default(true) @map("is_active")
  createdAt      Int     @map("created_at")
  updatedAt      Int     @map("updated_at")

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_promotion_codes_tenant_fkey")
  coupon      Coupon                 @relation(fields: [tenantId, couponId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_promotion_codes_coupon_fkey")
  customer    Customer?              @relation(fields: [tenantId, customerId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_promotion_codes_customer_fkey")
  discounts   SubscriptionDiscount[]
  redemptions CouponRedemption[]

  @@unique([tenantId, id], map: "billing_promotion_codes_tenant_id_id_key")
  @@unique([tenantId, code], map: "billing_promotion_codes_tenant_id_code_key")
  @@index([tenantId, isActive], map: "billing_promotion_codes_tenant_active_idx")
  @@index([couponId], map: "billing_promotion_codes_coupon_id_idx")
  @@index([customerId], map: "billing_promotion_codes_customer_id_idx")
  @@map("billing_promotion_codes")
}
