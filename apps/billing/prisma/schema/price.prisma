/// An immutable monetary offer attached to either an item or a plan. New prices
/// are created instead of changing an amount used by an existing agreement.
/// `entitlementReferenceId` is an optional opaque link to the core entitlement
/// price record this price mirrors.
model Price {
  id                     String        @id
  tenantId               String        @map("tenant_id")
  itemId                 String?       @map("item_id")
  planId                 String?       @map("plan_id")
  addonId                String?       @map("addon_id")
  nickname               String?
  entitlementReferenceId String?       @map("entitlement_reference_id")
  currency               String
  unitAmount             BigInt?       @map("unit_amount")
  pricingModel           PricingModel  @default(FLAT) @map("pricing_model")
  priceType              PriceType     @default(ONE_TIME) @map("price_type")
  intervalUnit           IntervalUnit? @map("interval_unit")
  intervalCount          Int?          @map("interval_count")
  unitName               String?       @map("unit_name")
  packageSize            Int?          @map("package_size")
  isTaxable              Boolean       @default(false) @map("is_taxable")
  isActive               Boolean       @default(true) @map("is_active")
  metadata               Json?
  createdAt              Int           @map("created_at")
  updatedAt              Int           @map("updated_at")

  tenant                     Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item                       Item?                       @relation(fields: [itemId], references: [id], onDelete: Restrict)
  plan                       Plan?                       @relation(fields: [planId], references: [id], onDelete: Restrict)
  addon                      Addon?                      @relation(fields: [addonId], references: [id], onDelete: Restrict)
  tiers                      PriceTier[]
  subscriptionItems          SubscriptionItem[]
  subscriptionAmendmentItems SubscriptionAmendmentItem[]
  subscriptionCharges        SubscriptionCharge[]
  quoteLines                 QuoteLine[]
  estimateLines              EstimateLine[]
  invoiceLines               InvoiceLine[]
  creditNoteLines            CreditNoteLine[]
  priceListEntries           PriceListEntry[]

  @@unique([tenantId, entitlementReferenceId], name: "billing_prices_tenant_entitlement_reference_key")
  @@index([tenantId], name: "billing_prices_tenant_id_idx")
  @@index([itemId], name: "billing_prices_item_id_idx")
  @@index([planId], name: "billing_prices_plan_id_idx")
  @@index([addonId], name: "billing_prices_addon_id_idx")
  @@map("billing_prices")
}

/// Quantity tiers used by volume and graduated/tiered prices. No provider
/// calculation is performed in this foundation; the structure is preserved for
/// a future calculation engine or provider adapter.
model PriceTier {
  id         String  @id
  priceId    String  @map("price_id")
  fromUnit   Int     @default(1) @map("from_unit")
  toUnit     Int?    @map("to_unit")
  unitAmount BigInt? @map("unit_amount")
  flatAmount BigInt? @map("flat_amount")
  createdAt  Int     @map("created_at")
  updatedAt  Int     @map("updated_at")

  price Price @relation(fields: [priceId], references: [id], onDelete: Cascade)

  @@unique([priceId, fromUnit], name: "billing_price_tiers_price_id_from_unit_key")
  @@index([priceId], name: "billing_price_tiers_price_id_idx")
  @@map("billing_price_tiers")
}
