/// An immutable monetary offer attached to either an item or a plan. New prices
/// are created instead of changing an amount used by an existing agreement.
/// `entitlementReferenceId` is an optional opaque link to the core entitlement
/// price record this price mirrors.
model Price {
  id                     String        @id
  tenantId               String        @map("tenant_id")
  itemId                 String?       @map("item_id")
  planId                 String?       @map("plan_id")
  addonId                String?       @map("addon_id")
  nickname               String?
  entitlementReferenceId String?       @map("entitlement_reference_id")
  currency               String
  unitAmount             BigInt?       @map("unit_amount")
  pricingModel           PricingModel  @default(FLAT) @map("pricing_model")
  priceType              PriceType     @default(ONE_TIME) @map("price_type")
  intervalUnit           IntervalUnit? @map("interval_unit")
  intervalCount          Int?          @map("interval_count")
  unitName               String?       @map("unit_name")
  packageSize            Int?          @map("package_size")
  isTaxable              Boolean       @default(false) @map("is_taxable")
  isActive               Boolean       @default(true) @map("is_active")
  metadata               Json?
  createdAt              Int           @map("created_at")
  updatedAt              Int           @map("updated_at")

  tenant                     Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_prices_tenant_id_fkey")
  item                       Item?                       @relation(fields: [itemId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "billing_prices_item_id_fkey")
  plan                       Plan?                       @relation(fields: [planId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "billing_prices_plan_id_fkey")
  addon                      Addon?                      @relation(fields: [addonId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "billing_prices_addon_fkey")
  tiers                      PriceTier[]
  subscriptionItems          SubscriptionItem[]
  subscriptionAmendmentItems SubscriptionAmendmentItem[]
  subscriptionCharges        SubscriptionCharge[]
  quoteLines                 QuoteLine[]
  estimateLines              EstimateLine[]
  invoiceLines               InvoiceLine[]
  creditNoteLines            CreditNoteLine[]
  priceListEntries           PriceListEntry[]

  @@unique([tenantId, entitlementReferenceId], name: "billing_prices_tenant_entitlement_reference_key", map: "billing_prices_tenant_id_entitlement_reference_id_key")
  @@index([tenantId], map: "billing_prices_tenant_id_idx")
  @@index([itemId], map: "billing_prices_item_id_idx")
  @@index([planId], map: "billing_prices_plan_id_idx")
  @@index([addonId], map: "billing_prices_addon_id_idx")
  @@map("billing_prices")
}
