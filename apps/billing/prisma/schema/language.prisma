/// A supported display/communication language. Billing seeds English only;
/// tenants and customers reference a language by its opaque code. Additional
/// languages are added by seeding new rows, never by hardcoding in app code.
model Language {
  code      String  @id
  name      String
  isActive  Boolean @default(true) @map("is_active")
  createdAt Int     @map("created_at")
  updatedAt Int     @map("updated_at")

  defaultForTenants Tenant[]   @relation("TenantDefaultLanguage")
  customers         Customer[] @relation("CustomerLanguage")

  @@map("billing_languages")
}
