/// Optional commercial owner used for attribution and future commission
/// reporting. It does not grant Billing permissions.
model Salesperson {
  id                String  @id
  tenantId          String  @map("tenant_id")
  name              String  @db.VarChar(160)
  email             String?
  externalReference String? @map("external_reference")
  isActive          Boolean @default(true) @map("is_active")
  createdAt         Int     @map("created_at")
  updatedAt         Int     @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers Customer[]
  invoices  Invoice[]

  @@unique([tenantId, id])
  @@unique([tenantId, externalReference])
  @@index([tenantId, isActive], name: "billing_salespeople_tenant_active_idx")
  @@map("billing_salespeople")
}
