
/// An immutable snapshot of an item/price at the time it was added to an estimate.
model EstimateLine {
  id             String  @id
  estimateId     String  @map("estimate_id")
  itemId         String? @map("item_id")
  priceId        String? @map("price_id")
  description    String
  quantity       Int     @default(1)
  unitAmount     BigInt  @map("unit_amount")
  taxAmount      BigInt  @default(0) @map("tax_amount")
  discountAmount BigInt  @default(0) @map("discount_amount")
  totalAmount    BigInt  @map("total_amount")
  createdAt      Int     @map("created_at")
  updatedAt      Int     @map("updated_at")

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_estimate_lines_estimate_id_fkey")
  item     Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "billing_estimate_lines_item_id_fkey")
  price    Price?   @relation(fields: [priceId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "billing_estimate_lines_price_id_fkey")

  @@index([estimateId], map: "billing_estimate_lines_estimate_id_idx")
  @@index([itemId], map: "billing_estimate_lines_item_id_idx")
  @@index([priceId], map: "billing_estimate_lines_price_id_idx")
  @@map("billing_estimate_lines")
}
