// 876 Billing's bounded-context database (Prisma 7, multi-file schema).
//
// Billing owns its tenants, customers, catalogue, commercial documents,
// subscriptions, payments, and lifecycle history. Core 876 entities are
// referenced only by opaque IDs; they never have cross-database foreign keys
// here. Provider payment processing, automated bank feeds, general-ledger
// accounting, tax calculation, and entitlement behavior remain separate
// concerns.

generator client {
  provider = "prisma-client"
  output   = "../../src/lib/db/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
