/// A credit note (credit memo): reduces a customer's receivable / recognized
/// revenue without moving cash. Its remaining `balanceAmount` can be applied to
/// open invoices, held as customer credit, or refunded. Issued for returns,
/// overcharges, or to document an overpayment. It is not a payment.
model CreditNote {
  id             String           @id
  tenantId       String           @map("tenant_id")
  customerId     String           @map("customer_id")
  /// Optional invoice this credit note was raised against.
  invoiceId      String?          @map("invoice_id")
  number         String
  status         CreditNoteStatus @default(DRAFT)
  currency       String
  reason         String?
  subtotalAmount BigInt           @default(0) @map("subtotal_amount")
  taxAmount      BigInt           @default(0) @map("tax_amount")
  totalAmount    BigInt           @default(0) @map("total_amount")
  /// Credit not yet applied to an invoice or refunded (starts at totalAmount).
  balanceAmount  BigInt           @default(0) @map("balance_amount")
  notes          String?
  terms          String?
  metadata       Json?
  issueAt        Int?             @map("issue_at")
  voidedAt       Int?             @map("voided_at")
  createdAt      Int              @map("created_at")
  updatedAt      Int              @map("updated_at")

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_credit_notes_tenant_id_fkey")
  customer      Customer               @relation(fields: [tenantId, customerId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_credit_notes_customer_fkey")
  invoice       Invoice?               @relation("InvoiceCreditNotes", fields: [invoiceId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "billing_credit_notes_invoice_fkey")
  lines         CreditNoteLine[]
  allocations   CreditNoteAllocation[]
  refunds       Refund[]
  ledgerEntries CustomerLedgerEntry[]

  @@unique([tenantId, id], map: "billing_credit_notes_tenant_id_id_key")
  @@unique([tenantId, number], name: "billing_credit_notes_tenant_id_number_key", map: "billing_credit_notes_tenant_id_number_key")
  @@index([tenantId, status], map: "billing_credit_notes_tenant_id_status_idx")
  @@index([customerId], map: "billing_credit_notes_customer_id_idx")
  @@index([invoiceId], map: "billing_credit_notes_invoice_id_idx")
  @@map("billing_credit_notes")
}
