/// A credit note (credit memo): reduces a customer's receivable / recognized
/// revenue without moving cash. Its remaining `balanceAmount` can be applied to
/// open invoices, held as customer credit, or refunded. Issued for returns,
/// overcharges, or to document an overpayment. It is not a payment.
model CreditNote {
  id             String           @id
  tenantId       String           @map("tenant_id")
  customerId     String           @map("customer_id")
  /// Optional invoice this credit note was raised against.
  invoiceId      String?          @map("invoice_id")
  number         String
  status         CreditNoteStatus @default(DRAFT)
  currency       String
  reason         String?
  subtotalAmount BigInt           @default(0) @map("subtotal_amount")
  taxAmount      BigInt           @default(0) @map("tax_amount")
  totalAmount    BigInt           @default(0) @map("total_amount")
  /// Credit not yet applied to an invoice or refunded (starts at totalAmount).
  balanceAmount  BigInt           @default(0) @map("balance_amount")
  notes          String?
  terms          String?
  metadata       Json?
  issueAt        Int?             @map("issue_at")
  voidedAt       Int?             @map("voided_at")
  createdAt      Int              @map("created_at")
  updatedAt      Int              @map("updated_at")

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer      Customer               @relation(fields: [tenantId, customerId], references: [tenantId, id], onDelete: Restrict)
  invoice       Invoice?               @relation("InvoiceCreditNotes", fields: [invoiceId], references: [id], onDelete: SetNull)
  lines         CreditNoteLine[]
  allocations   CreditNoteAllocation[]
  refunds       Refund[]
  ledgerEntries CustomerLedgerEntry[]

  @@unique([tenantId, id])
  @@unique([tenantId, number], name: "billing_credit_notes_tenant_id_number_key")
  @@index([tenantId, status], name: "billing_credit_notes_tenant_id_status_idx")
  @@index([customerId], name: "billing_credit_notes_customer_id_idx")
  @@index([invoiceId], name: "billing_credit_notes_invoice_id_idx")
  @@map("billing_credit_notes")
}

/// An immutable snapshot of an item/price at the time it was added to a credit note.
model CreditNoteLine {
  id             String  @id
  creditNoteId   String  @map("credit_note_id")
  itemId         String? @map("item_id")
  priceId        String? @map("price_id")
  description    String
  quantity       Int     @default(1)
  unitAmount     BigInt  @map("unit_amount")
  taxAmount      BigInt  @default(0) @map("tax_amount")
  discountAmount BigInt  @default(0) @map("discount_amount")
  totalAmount    BigInt  @map("total_amount")
  createdAt      Int     @map("created_at")
  updatedAt      Int     @map("updated_at")

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  item       Item?      @relation(fields: [itemId], references: [id], onDelete: SetNull)
  price      Price?     @relation(fields: [priceId], references: [id], onDelete: SetNull)

  @@index([creditNoteId], name: "billing_credit_note_lines_credit_note_id_idx")
  @@index([itemId], name: "billing_credit_note_lines_item_id_idx")
  @@index([priceId], name: "billing_credit_note_lines_price_id_idx")
  @@map("billing_credit_note_lines")
}

/// The portion of one credit note applied to one invoice, reducing that
/// invoice's balance. Mirrors PaymentAllocation and captures the invoice's
/// prior state so an application can be reversed.
model CreditNoteAllocation {
  id                  String        @id
  tenantId            String        @map("tenant_id")
  creditNoteId        String        @map("credit_note_id")
  invoiceId           String        @map("invoice_id")
  amount              BigInt
  invoiceStatusBefore InvoiceStatus @map("invoice_status_before")
  invoicePaidAtBefore Int?          @map("invoice_paid_at_before")
  reversedAt          Int?          @map("reversed_at")
  createdAt           Int           @map("created_at")
  updatedAt           Int           @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creditNote CreditNote @relation(fields: [tenantId, creditNoteId], references: [tenantId, id], onDelete: Cascade)
  invoice    Invoice    @relation(fields: [tenantId, invoiceId], references: [tenantId, id], onDelete: Restrict)

  @@index([tenantId, creditNoteId], name: "billing_credit_note_allocations_tenant_credit_note_idx")
  @@index([tenantId, invoiceId], name: "billing_credit_note_allocations_tenant_invoice_idx")
  @@index([tenantId, creditNoteId, reversedAt], name: "billing_credit_note_allocations_active_idx")
  @@map("billing_credit_note_allocations")
}
