
/// A credit or debit recorded against a financial account. Payment-generated
/// credits keep a direct one-to-one link to their source payment.
model BankTransaction {
  id          String                @id
  tenantId    String                @map("tenant_id")
  accountId   String                @map("account_id")
  paymentId   String?               @map("payment_id")
  type        BankTransactionType
  amount      BigInt
  date        Int
  description String?               @db.Text
  status      BankTransactionStatus @default(UNCATEGORIZED)
  reference   String?               @db.VarChar(120)
  createdAt   Int                   @map("created_at")
  updatedAt   Int                   @map("updated_at")

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_bank_transactions_tenant_id_fkey")
  account BankAccount @relation(fields: [tenantId, accountId], references: [tenantId, id], onDelete: Cascade, onUpdate: Cascade, map: "billing_bank_transactions_account_fkey")
  payment Payment?    @relation(fields: [tenantId, paymentId], references: [tenantId, id], onDelete: Cascade, onUpdate: Cascade, map: "billing_bank_transactions_payment_fkey")

  @@unique([tenantId, paymentId], map: "billing_bank_transactions_tenant_id_payment_id_key")
  @@index([tenantId, accountId, date], map: "billing_bank_transactions_tenant_account_date_idx")
  @@index([tenantId, date], map: "billing_bank_transactions_tenant_id_date_idx")
  @@index([accountId], map: "billing_bank_transactions_account_id_idx")
  @@index([paymentId], map: "billing_bank_transactions_payment_id_idx")
  @@map("billing_bank_transactions")
}
