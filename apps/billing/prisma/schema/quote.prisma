/// A non-binding sales proposal. Quote acceptance can later create an invoice
/// or subscription, but this release does not send or collect payment.
model Quote {
  id             String      @id
  tenantId       String      @map("tenant_id")
  customerId     String      @map("customer_id")
  priceListId    String?     @map("price_list_id")
  priceListName  String?     @map("price_list_name")
  number         String
  status         QuoteStatus @default(DRAFT)
  currency       String
  issueAt        Int?        @map("issue_at")
  expiresAt      Int?        @map("expires_at")
  acceptedAt     Int?        @map("accepted_at")
  declinedAt     Int?        @map("declined_at")
  canceledAt     Int?        @map("canceled_at")
  subtotalAmount BigInt      @default(0) @map("subtotal_amount")
  taxAmount      BigInt      @default(0) @map("tax_amount")
  totalAmount    BigInt      @default(0) @map("total_amount")
  notes          String?
  terms          String?
  metadata       Json?
  createdAt      Int         @map("created_at")
  updatedAt      Int         @map("updated_at")

  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_quotes_tenant_id_fkey")
  customer         Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "billing_quotes_customer_id_fkey")
  priceList        PriceList?  @relation(fields: [tenantId, priceListId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_quotes_price_list_fkey")
  lines            QuoteLine[]
  convertedInvoice Invoice?    @relation("QuoteConvertedInvoice")

  @@unique([tenantId, number], name: "billing_quotes_tenant_id_number_key", map: "billing_quotes_tenant_id_number_key")
  @@index([tenantId, status], map: "billing_quotes_tenant_id_status_idx")
  @@index([customerId], map: "billing_quotes_customer_id_idx")
  @@index([priceListId], map: "billing_quotes_price_list_id_idx")
  @@map("billing_quotes")
}
