
/// An immutable snapshot of an item/price at the time it was added to a quote.
model QuoteLine {
  id             String  @id
  quoteId        String  @map("quote_id")
  itemId         String? @map("item_id")
  priceId        String? @map("price_id")
  description    String
  quantity       Int     @default(1)
  unitAmount     BigInt  @map("unit_amount")
  taxAmount      BigInt  @default(0) @map("tax_amount")
  discountAmount BigInt  @default(0) @map("discount_amount")
  totalAmount    BigInt  @map("total_amount")
  createdAt      Int     @map("created_at")
  updatedAt      Int     @map("updated_at")

  quote Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_quote_lines_quote_id_fkey")
  item  Item?  @relation(fields: [itemId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "billing_quote_lines_item_id_fkey")
  price Price? @relation(fields: [priceId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "billing_quote_lines_price_id_fkey")

  @@index([quoteId], map: "billing_quote_lines_quote_id_idx")
  @@index([itemId], map: "billing_quote_lines_item_id_idx")
  @@index([priceId], map: "billing_quote_lines_price_id_idx")
  @@map("billing_quote_lines")
}
