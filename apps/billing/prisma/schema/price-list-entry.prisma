
model PriceListEntry {
  id          String  @id
  tenantId    String  @map("tenant_id")
  priceListId String  @map("price_list_id")
  priceId     String  @map("price_id")
  unitAmount  BigInt? @map("unit_amount")
  createdAt   Int     @map("created_at")
  updatedAt   Int     @map("updated_at")

  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_price_list_entries_tenant_fkey")
  priceList PriceList            @relation(fields: [tenantId, priceListId], references: [tenantId, id], onDelete: Cascade, onUpdate: Cascade, map: "billing_price_list_entries_list_fkey")
  price     Price                @relation(fields: [priceId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "billing_price_list_entries_price_fkey")
  tiers     PriceListEntryTier[]

  @@unique([tenantId, priceListId, priceId], name: "billing_price_list_entries_price_key", map: "billing_price_list_entries_price_key")
  @@index([priceListId], map: "billing_price_list_entries_list_idx")
  @@index([priceId], map: "billing_price_list_entries_price_idx")
  @@map("billing_price_list_entries")
}
