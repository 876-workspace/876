/// A non-binding sales estimate. Similar to a quote.
model Estimate {
  id             String         @id
  tenantId       String         @map("tenant_id")
  customerId     String         @map("customer_id")
  priceListId    String?        @map("price_list_id")
  priceListName  String?        @map("price_list_name")
  number         String
  status         EstimateStatus @default(DRAFT)
  currency       String
  issueAt        Int?           @map("issue_at")
  expiresAt      Int?           @map("expires_at")
  acceptedAt     Int?           @map("accepted_at")
  declinedAt     Int?           @map("declined_at")
  canceledAt     Int?           @map("canceled_at")
  subtotalAmount BigInt         @default(0) @map("subtotal_amount")
  taxAmount      BigInt         @default(0) @map("tax_amount")
  totalAmount    BigInt         @default(0) @map("total_amount")
  notes          String?
  terms          String?
  metadata       Json?
  createdAt      Int            @map("created_at")
  updatedAt      Int            @map("updated_at")

  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer         Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  priceList        PriceList?     @relation(fields: [tenantId, priceListId], references: [tenantId, id], onDelete: Restrict)
  lines            EstimateLine[]
  convertedInvoice Invoice?       @relation("EstimateConvertedInvoice")

  @@unique([tenantId, number], name: "billing_estimates_tenant_id_number_key")
  @@index([tenantId, status], name: "billing_estimates_tenant_id_status_idx")
  @@index([customerId], name: "billing_estimates_customer_id_idx")
  @@index([priceListId], name: "billing_estimates_price_list_id_idx")
  @@map("billing_estimates")
}

/// An immutable snapshot of an item/price at the time it was added to an estimate.
model EstimateLine {
  id             String  @id
  estimateId     String  @map("estimate_id")
  itemId         String? @map("item_id")
  priceId        String? @map("price_id")
  description    String
  quantity       Int     @default(1)
  unitAmount     BigInt  @map("unit_amount")
  taxAmount      BigInt  @default(0) @map("tax_amount")
  discountAmount BigInt  @default(0) @map("discount_amount")
  totalAmount    BigInt  @map("total_amount")
  createdAt      Int     @map("created_at")
  updatedAt      Int     @map("updated_at")

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  item     Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
  price    Price?   @relation(fields: [priceId], references: [id], onDelete: SetNull)

  @@index([estimateId], name: "billing_estimate_lines_estimate_id_idx")
  @@index([itemId], name: "billing_estimate_lines_item_id_idx")
  @@index([priceId], name: "billing_estimate_lines_price_id_idx")
  @@map("billing_estimate_lines")
}
