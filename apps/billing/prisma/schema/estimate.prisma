/// A non-binding sales estimate. Similar to a quote.
model Estimate {
  id             String         @id
  tenantId       String         @map("tenant_id")
  customerId     String         @map("customer_id")
  priceListId    String?        @map("price_list_id")
  priceListName  String?        @map("price_list_name")
  number         String
  status         EstimateStatus @default(DRAFT)
  currency       String
  issueAt        Int?           @map("issue_at")
  expiresAt      Int?           @map("expires_at")
  acceptedAt     Int?           @map("accepted_at")
  declinedAt     Int?           @map("declined_at")
  canceledAt     Int?           @map("canceled_at")
  subtotalAmount BigInt         @default(0) @map("subtotal_amount")
  taxAmount      BigInt         @default(0) @map("tax_amount")
  totalAmount    BigInt         @default(0) @map("total_amount")
  notes          String?
  terms          String?
  metadata       Json?
  createdAt      Int            @map("created_at")
  updatedAt      Int            @map("updated_at")

  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_estimates_tenant_id_fkey")
  customer         Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "billing_estimates_customer_id_fkey")
  priceList        PriceList?     @relation(fields: [tenantId, priceListId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_estimates_price_list_fkey")
  lines            EstimateLine[]
  convertedInvoice Invoice?       @relation("EstimateConvertedInvoice")

  @@unique([tenantId, number], name: "billing_estimates_tenant_id_number_key", map: "billing_estimates_tenant_id_number_key")
  @@index([tenantId, status], map: "billing_estimates_tenant_id_status_idx")
  @@index([customerId], map: "billing_estimates_customer_id_idx")
  @@index([priceListId], map: "billing_estimates_price_list_id_idx")
  @@map("billing_estimates")
}
