/// Append-only customer subledger event used for statements, reconciliation,
/// aging, and a future double-entry general-ledger projection.
model CustomerLedgerEntry {
  id             String          @id
  tenantId       String          @map("tenant_id")
  customerId     String          @map("customer_id")
  subscriptionId String?         @map("subscription_id")
  invoiceId      String?         @map("invoice_id")
  paymentId      String?         @map("payment_id")
  creditNoteId   String?         @map("credit_note_id")
  refundId       String?         @map("refund_id")
  type           LedgerEntryType
  direction      LedgerDirection
  amount         BigInt
  currency       String          @db.Char(3)
  description    String?
  idempotencyKey String          @map("idempotency_key")
  effectiveAt    Int             @map("effective_at")
  createdAt      Int             @map("created_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_ledger_tenant_fkey")
  customer     Customer      @relation(fields: [tenantId, customerId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_ledger_customer_fkey")
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "billing_ledger_subscription_fkey")
  invoice      Invoice?      @relation(fields: [tenantId, invoiceId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_ledger_invoice_fkey")
  payment      Payment?      @relation(fields: [tenantId, paymentId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_ledger_payment_fkey")
  creditNote   CreditNote?   @relation(fields: [tenantId, creditNoteId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_ledger_credit_note_fkey")
  refund       Refund?       @relation(fields: [tenantId, refundId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_ledger_refund_fkey")

  @@unique([tenantId, id], map: "billing_customer_ledger_entries_tenant_id_id_key")
  @@unique([tenantId, idempotencyKey], map: "billing_customer_ledger_entries_tenant_idempotency_key")
  @@index([tenantId, customerId, effectiveAt], map: "billing_ledger_tenant_customer_date_idx")
  @@index([tenantId, type, effectiveAt], map: "billing_ledger_tenant_type_date_idx")
  @@index([creditNoteId], map: "billing_customer_ledger_entries_credit_note_id_idx")
  @@index([customerId], map: "billing_customer_ledger_entries_customer_id_idx")
  @@index([invoiceId], map: "billing_customer_ledger_entries_invoice_id_idx")
  @@index([paymentId], map: "billing_customer_ledger_entries_payment_id_idx")
  @@index([refundId], map: "billing_customer_ledger_entries_refund_id_idx")
  @@index([subscriptionId], map: "billing_customer_ledger_entries_subscription_id_idx")
  @@map("billing_customer_ledger_entries")
}
