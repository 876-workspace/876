/// Reusable discount definition. Promotion codes and direct gifts reference a
/// coupon instead of cloning a plan or mutating an immutable price.
model Coupon {
  id                          String                   @id
  tenantId                    String                   @map("tenant_id")
  productId                   String?                  @map("product_id")
  name                        String
  discountType                DiscountType             @map("discount_type")
  percentOff                  Decimal?                 @map("percent_off") @db.Decimal(7, 4)
  amountOff                   BigInt?                  @map("amount_off")
  currency                    String?                  @db.Char(3)
  duration                    DiscountDuration
  durationInCycles            Int?                     @map("duration_in_cycles")
  discountPreference          CouponDiscountPreference @default(INVOICE_LEVEL) @map("discount_preference")
  appliesToAllPlans           Boolean                  @default(true) @map("applies_to_all_plans")
  appliesToAllRecurringAddons Boolean                  @default(true) @map("applies_to_all_recurring_addons")
  appliesToAllOneTimeAddons   Boolean                  @default(true) @map("applies_to_all_one_time_addons")
  eligibleForAllCustomers     Boolean                  @default(true) @map("eligible_for_all_customers")
  maxRedemptionsPerCustomer   Int?                     @map("max_redemptions_per_customer")
  redeemBy                    Int?                     @map("redeem_by")
  maxRedemptions              Int?                     @map("max_redemptions")
  timesRedeemed               Int                      @default(0) @map("times_redeemed")
  isActive                    Boolean                  @default(true) @map("is_active")
  metadata                    Json?
  createdAt                   Int                      @map("created_at")
  updatedAt                   Int                      @map("updated_at")

  tenant                Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product               Product?                    @relation(fields: [productId], references: [id], onDelete: SetNull)
  promotionCodes        PromotionCode[]
  discounts             SubscriptionDiscount[]
  currencyAmounts       CouponCurrencyAmount[]
  planApplicabilities   CouponPlanApplicability[]
  addonApplicabilities  CouponAddonApplicability[]
  customerEligibilities CouponCustomerEligibility[]
  redemptions           CouponRedemption[]

  @@unique([tenantId, id])
  @@index([tenantId, isActive], name: "billing_coupons_tenant_active_idx")
  @@map("billing_coupons")
}

/// Customer-facing redemption code separated from the discount definition.
model PromotionCode {
  id             String  @id
  tenantId       String  @map("tenant_id")
  couponId       String  @map("coupon_id")
  code           String
  customerId     String? @map("customer_id")
  expiresAt      Int?    @map("expires_at")
  maxRedemptions Int?    @map("max_redemptions")
  timesRedeemed  Int     @default(0) @map("times_redeemed")
  isActive       Boolean @default(true) @map("is_active")
  createdAt      Int     @map("created_at")
  updatedAt      Int     @map("updated_at")

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  coupon      Coupon                 @relation(fields: [tenantId, couponId], references: [tenantId, id], onDelete: Restrict)
  customer    Customer?              @relation(fields: [tenantId, customerId], references: [tenantId, id], onDelete: Restrict)
  discounts   SubscriptionDiscount[]
  redemptions CouponRedemption[]

  @@unique([tenantId, id])
  @@unique([tenantId, code])
  @@index([tenantId, isActive], name: "billing_promotion_codes_tenant_active_idx")
  @@map("billing_promotion_codes")
}

/// Currency-specific fixed discount values. The original amount/currency pair
/// on Coupon remains the base-currency fallback for existing integrations.
model CouponCurrencyAmount {
  id        String @id
  tenantId  String @map("tenant_id")
  couponId  String @map("coupon_id")
  currency  String @db.Char(3)
  amountOff BigInt @map("amount_off")
  createdAt Int    @map("created_at")
  updatedAt Int    @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  coupon Coupon @relation(fields: [tenantId, couponId], references: [tenantId, id], onDelete: Cascade)

  @@unique([tenantId, couponId, currency], name: "billing_coupon_currency_amounts_coupon_currency_key")
  @@index([couponId], name: "billing_coupon_currency_amounts_coupon_idx")
  @@index([tenantId, currency], name: "billing_coupon_currency_amounts_tenant_currency_idx")
  @@map("billing_coupon_currency_amounts")
}

model CouponPlanApplicability {
  id        String @id
  tenantId  String @map("tenant_id")
  couponId  String @map("coupon_id")
  planId    String @map("plan_id")
  createdAt Int    @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  coupon Coupon @relation(fields: [tenantId, couponId], references: [tenantId, id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([tenantId, couponId, planId], name: "billing_coupon_plan_applicability_key")
  @@index([couponId], name: "billing_coupon_plan_applicability_coupon_idx")
  @@index([planId], name: "billing_coupon_plan_applicability_plan_idx")
  @@map("billing_coupon_plan_applicabilities")
}

model CouponAddonApplicability {
  id        String @id
  tenantId  String @map("tenant_id")
  couponId  String @map("coupon_id")
  addonId   String @map("addon_id")
  createdAt Int    @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  coupon Coupon @relation(fields: [tenantId, couponId], references: [tenantId, id], onDelete: Cascade)
  addon  Addon  @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@unique([tenantId, couponId, addonId], name: "billing_coupon_addon_applicability_key")
  @@index([couponId], name: "billing_coupon_addon_applicability_coupon_idx")
  @@index([addonId], name: "billing_coupon_addon_applicability_addon_idx")
  @@map("billing_coupon_addon_applicabilities")
}

model CouponCustomerEligibility {
  id         String @id
  tenantId   String @map("tenant_id")
  couponId   String @map("coupon_id")
  customerId String @map("customer_id")
  createdAt  Int    @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  coupon   Coupon   @relation(fields: [tenantId, couponId], references: [tenantId, id], onDelete: Cascade)
  customer Customer @relation(fields: [tenantId, customerId], references: [tenantId, id], onDelete: Cascade)

  @@unique([tenantId, couponId, customerId], name: "billing_coupon_customer_eligibility_key")
  @@index([couponId], name: "billing_coupon_customer_eligibility_coupon_idx")
  @@index([customerId], name: "billing_coupon_customer_eligibility_customer_idx")
  @@map("billing_coupon_customer_eligibilities")
}

/// Append-only redemption evidence used for limits, reporting, and audits.
model CouponRedemption {
  id              String  @id
  tenantId        String  @map("tenant_id")
  couponId        String  @map("coupon_id")
  promotionCodeId String? @map("promotion_code_id")
  customerId      String  @map("customer_id")
  subscriptionId  String? @map("subscription_id")
  invoiceId       String? @map("invoice_id")
  discountAmount  BigInt? @map("discount_amount")
  currency        String? @db.Char(3)
  redeemedAt      Int     @map("redeemed_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  coupon        Coupon         @relation(fields: [tenantId, couponId], references: [tenantId, id], onDelete: Restrict)
  promotionCode PromotionCode? @relation(fields: [tenantId, promotionCodeId], references: [tenantId, id], onDelete: Restrict)
  customer      Customer       @relation(fields: [tenantId, customerId], references: [tenantId, id], onDelete: Restrict)
  subscription  Subscription?  @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  invoice       Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([tenantId, couponId, customerId], name: "billing_coupon_redemptions_coupon_customer_idx")
  @@index([promotionCodeId], name: "billing_coupon_redemptions_promotion_code_idx")
  @@index([subscriptionId], name: "billing_coupon_redemptions_subscription_idx")
  @@index([invoiceId], name: "billing_coupon_redemptions_invoice_idx")
  @@map("billing_coupon_redemptions")
}

/// Immutable redemption snapshot attached to a subscription. Direct gifts may
/// omit a promotion code while retaining their coupon and grant metadata.
model SubscriptionDiscount {
  id                 String                     @id
  tenantId           String                     @map("tenant_id")
  subscriptionId     String                     @map("subscription_id")
  couponId           String?                    @map("coupon_id")
  promotionCodeId    String?                    @map("promotion_code_id")
  subscriptionItemId String?                    @map("subscription_item_id")
  source             SubscriptionDiscountSource @default(COUPON)
  scope              SubscriptionDiscountScope  @default(TRANSACTION)
  status             DiscountStatus             @default(ACTIVE)
  discountType       DiscountType               @map("discount_type")
  percentOff         Decimal?                   @map("percent_off") @db.Decimal(7, 4)
  amountOff          BigInt?                    @map("amount_off")
  currency           String?                    @db.Char(3)
  duration           DiscountDuration
  remainingCycles    Int?                       @map("remaining_cycles")
  grantedByUserId    String?                    @map("granted_by_user_id")
  grantReason        String?                    @map("grant_reason")
  startsAt           Int                        @map("starts_at")
  endsAt             Int?                       @map("ends_at")
  createdAt          Int                        @map("created_at")
  updatedAt          Int                        @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription     Subscription      @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  coupon           Coupon?           @relation(fields: [tenantId, couponId], references: [tenantId, id], onDelete: Restrict)
  promotionCode    PromotionCode?    @relation(fields: [tenantId, promotionCodeId], references: [tenantId, id], onDelete: Restrict)
  subscriptionItem SubscriptionItem? @relation(fields: [subscriptionItemId], references: [id], onDelete: Restrict)

  @@unique([tenantId, id])
  @@index([subscriptionId, status], name: "billing_subscription_discounts_subscription_status_idx")
  @@index([subscriptionItemId], name: "billing_subscription_discounts_subscription_item_idx")
  @@map("billing_subscription_discounts")
}
