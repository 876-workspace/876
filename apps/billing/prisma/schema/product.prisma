/// A subscription product groups related plans, add-ons, and later reporting
/// dimensions. `sourceAppId` is an optional opaque link to an 876 application.
model Product {
  id                     String   @id
  tenantId               String   @map("tenant_id")
  sourceAppId            String?  @map("source_app_id")
  fallbackPlanId         String?  @map("fallback_plan_id")
  slug                   String
  name                   String
  description            String?
  type                   ItemType @default(SERVICE)
  notificationRecipients String?  @map("notification_recipients")
  redirectUrl            String?  @map("redirect_url")
  isActive               Boolean  @default(true) @map("is_active")
  metadata               Json?
  createdAt              Int      @map("created_at")
  updatedAt              Int      @map("updated_at")

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_products_tenant_id_fkey")
  fallbackPlan Plan?    @relation("ProductFallbackPlan", fields: [fallbackPlanId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "billing_products_fallback_plan_fkey")
  plans        Plan[]
  addons       Addon[]
  coupons      Coupon[]

  @@unique([tenantId, slug], name: "billing_products_tenant_id_slug_key", map: "billing_products_tenant_id_slug_key")
  @@index([tenantId], map: "billing_products_tenant_id_idx")
  @@index([sourceAppId], map: "billing_products_source_app_id_idx")
  @@index([fallbackPlanId], map: "billing_products_fallback_plan_id_idx")
  @@map("billing_products")
}
