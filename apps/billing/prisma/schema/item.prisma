/// A tenant-owned sellable item used on quotes and invoices. It can represent a
/// physical good or a service and can optionally carry default sale/cost values.
model Item {
  id                      String   @id
  tenantId                String   @map("tenant_id")
  sourceAppId             String?  @map("source_app_id")
  sourceExternalReference String?  @map("source_external_reference")
  sourceIdempotencyKey    String?  @map("source_idempotency_key")
  sourcePayloadHash       String?  @map("source_payload_hash")
  type                    ItemType
  name                    String
  sku                     String?
  unit                    String?
  description             String?
  imageUrl                String?  @map("image_url")
  defaultSellingAmount    BigInt?  @map("default_selling_amount")
  defaultSellingCurrency  String?  @map("default_selling_currency")
  defaultCostAmount       BigInt?  @map("default_cost_amount")
  defaultCostCurrency     String?  @map("default_cost_currency")
  isTaxable               Boolean  @default(false) @map("is_taxable")
  taxCode                 String?  @map("tax_code")
  isActive                Boolean  @default(true) @map("is_active")
  metadata                Json?
  createdAt               Int      @map("created_at")
  updatedAt               Int      @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prices          Price[]
  quoteLines      QuoteLine[]
  estimateLines   EstimateLine[]
  invoiceLines    InvoiceLine[]
  creditNoteLines CreditNoteLine[]

  @@unique([tenantId, sku], name: "billing_items_tenant_id_sku_key")
  @@unique([tenantId, sourceAppId, sourceExternalReference], name: "billing_items_source_external_key")
  @@unique([tenantId, sourceAppId, sourceIdempotencyKey], name: "billing_items_source_idempotency_key")
  @@index([tenantId], name: "billing_items_tenant_id_idx")
  @@index([tenantId, sourceAppId], name: "billing_items_source_app_idx")
  @@map("billing_items")
}
