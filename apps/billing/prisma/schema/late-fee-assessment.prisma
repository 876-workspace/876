
/// Immutable evidence of one late-fee decision. The assessment records the
/// policy and balance used even if workspace preferences later change.
model LateFeeAssessment {
  id               String                 @id
  tenantId         String                 @map("tenant_id")
  sourceInvoiceId  String                 @map("source_invoice_id")
  lateFeeInvoiceId String                 @unique @map("late_fee_invoice_id")
  calculationType  LateFeeCalculationType @map("calculation_type")
  baseAmount       BigInt                 @map("base_amount")
  percent          Decimal?               @db.Decimal(7, 4)
  fixedAmount      BigInt?                @map("fixed_amount")
  assessedAmount   BigInt                 @map("assessed_amount")
  graceDays        Int                    @map("grace_days")
  assessedAt       Int                    @map("assessed_at")
  createdAt        Int                    @map("created_at")

  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_late_fee_assessments_tenant_id_fkey")
  sourceInvoice  Invoice @relation("LateFeeSourceInvoice", fields: [sourceInvoiceId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "billing_late_fee_assessments_source_invoice_id_fkey")
  lateFeeInvoice Invoice @relation("LateFeeInvoice", fields: [lateFeeInvoiceId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "billing_late_fee_assessments_late_fee_invoice_id_fkey")

  @@unique([tenantId, id], map: "billing_late_fee_assessments_tenant_id_id_key")
  @@unique([tenantId, sourceInvoiceId], name: "billing_late_fee_assessments_tenant_source_key", map: "billing_late_fee_assessments_tenant_id_source_invoice_id_key")
  @@index([tenantId, assessedAt], map: "billing_late_fee_assessments_tenant_date_idx")
  @@index([sourceInvoiceId], map: "billing_late_fee_assessments_source_invoice_id_idx")
  @@map("billing_late_fee_assessments")
}
