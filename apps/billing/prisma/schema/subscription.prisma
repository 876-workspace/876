/// A commercial agreement between a Billing tenant and customer. It is not an
/// invoice and does not represent a collected payment.
model Subscription {
  id                       String                   @id
  tenantId                 String                   @map("tenant_id")
  customerId               String                   @map("customer_id")
  sourceAppId              String?                  @map("source_app_id")
  externalReference        String?                  @map("external_reference")
  replacesSubscriptionId   String?                  @unique @map("replaces_subscription_id")
  status                   SubscriptionStatus       @default(DRAFT)
  startAt                  Int?                     @map("start_at")
  currentPeriodStart       Int?                     @map("current_period_start")
  currentPeriodEnd         Int?                     @map("current_period_end")
  servicePeriodStart       Int?                     @map("service_period_start")
  servicePeriodEnd         Int?                     @map("service_period_end")
  billingCycleAnchor       Int?                     @map("billing_cycle_anchor")
  nextBillingAt            Int?                     @map("next_billing_at")
  lastBilledAt             Int?                     @map("last_billed_at")
  billedCycleCount         Int                      @default(0) @map("billed_cycle_count")
  completedRegularCycles   Int                      @default(0) @map("completed_regular_cycles")
  hasInitialStubPeriod     Boolean                  @default(false) @map("has_initial_stub_period")
  trialEndsAt              Int?                     @map("trial_ends_at")
  collectionMethod         CollectionMethod         @default(SEND_INVOICE) @map("collection_method")
  billingTiming            BillingTiming            @default(IN_ADVANCE) @map("billing_timing")
  prorationBehavior        ProrationBehavior        @default(CREATE_PRORATIONS) @map("proration_behavior")
  paymentTermId            String?                  @map("payment_term_id")
  autoApplyCredits         Boolean                  @default(true) @map("auto_apply_credits")
  taxBehavior              TaxBehavior              @default(EXCLUSIVE) @map("tax_behavior")
  invoiceModeOverride      SubscriptionInvoiceMode? @map("invoice_mode_override")
  renewalPricingPolicy     RenewalPricingPolicy     @default(RETAIN_EXISTING) @map("renewal_pricing_policy")
  renewalAdjustmentPercent Decimal?                 @map("renewal_adjustment_percent") @db.Decimal(7, 4)
  lockActivationPrices     Boolean                  @default(true) @map("lock_activation_prices")
  remainingCycles          Int?                     @map("remaining_cycles")
  expiresAt                Int?                     @map("expires_at")
  priceListId              String?                  @map("price_list_id")
  priceListName            String?                  @map("price_list_name")
  advanceBillingEnabled    Boolean?                 @map("advance_billing_enabled")
  advanceBillingDays       Int?                     @map("advance_billing_days")
  nextAdvanceInvoiceAt     Int?                     @map("next_advance_invoice_at")
  cancelAtPeriodEnd        Boolean                  @default(false) @map("cancel_at_period_end")
  canceledAt               Int?                     @map("canceled_at")
  pausedAt                 Int?                     @map("paused_at")
  endedAt                  Int?                     @map("ended_at")
  deletedAt                Int?                     @map("deleted_at")
  entitlementReferenceId   String?                  @map("entitlement_reference_id")
  metadata                 Json?
  createdAt                Int                      @map("created_at")
  updatedAt                Int                      @map("updated_at")

  tenant                  Tenant                           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer                Customer                         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  replacesSubscription    Subscription?                    @relation("SubscriptionReactivation", fields: [replacesSubscriptionId], references: [id], onDelete: Restrict)
  replacementSubscription Subscription?                    @relation("SubscriptionReactivation")
  paymentTerm             PaymentTerm?                     @relation(fields: [tenantId, paymentTermId], references: [tenantId, id], onDelete: Restrict)
  priceList               PriceList?                       @relation(fields: [tenantId, priceListId], references: [tenantId, id], onDelete: Restrict)
  invoices                Invoice[]
  invoiceLinks            InvoiceSubscription[]
  items                   SubscriptionItem[]
  events                  SubscriptionEvent[]
  discounts               SubscriptionDiscount[]
  amendments              SubscriptionAmendment[]
  lifecycleSchedules      SubscriptionLifecycleSchedule[]
  charges                 SubscriptionCharge[]
  billingRuns             SubscriptionBillingRun[]
  paymentAttempts         PaymentAttempt[]
  ledgerEntries           CustomerLedgerEntry[]
  couponRedemptions       CouponRedemption[]
  notificationOutbox      SubscriptionNotificationOutbox[]

  @@unique([tenantId, externalReference], name: "billing_subscriptions_tenant_external_reference_key")
  @@index([tenantId], name: "billing_subscriptions_tenant_id_idx")
  @@index([customerId], name: "billing_subscriptions_customer_id_idx")
  @@index([status], name: "billing_subscriptions_status_idx")
  @@index([sourceAppId], name: "billing_subscriptions_source_app_id_idx")
  @@index([tenantId, nextBillingAt], name: "billing_subscriptions_tenant_next_billing_idx")
  @@index([tenantId, nextAdvanceInvoiceAt], name: "billing_subscriptions_tenant_next_advance_invoice_idx")
  @@index([priceListId], name: "billing_subscriptions_price_list_id_idx")
  @@index([tenantId, deletedAt], name: "billing_subscriptions_tenant_deleted_at_idx")
  @@map("billing_subscriptions")
}

model SubscriptionItem {
  id             String  @id
  subscriptionId String  @map("subscription_id")
  priceId        String  @map("price_id")
  quantity       Int     @default(1)
  unitAmount     BigInt? @map("unit_amount")
  currency       String?
  description    String?
  position       Int     @default(0)
  isActive       Boolean @default(true) @map("is_active")
  startsAt       Int?    @map("starts_at")
  endsAt         Int?    @map("ends_at")
  metadata       Json?
  createdAt      Int     @map("created_at")
  updatedAt      Int     @map("updated_at")

  subscription Subscription           @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  price        Price                  @relation(fields: [priceId], references: [id], onDelete: Restrict)
  invoiceLines InvoiceLine[]
  discounts    SubscriptionDiscount[]

  @@index([subscriptionId, isActive, position], name: "billing_subscription_items_active_position_idx")
  @@index([priceId], name: "billing_subscription_items_price_id_idx")
  @@map("billing_subscription_items")
}

/// Immutable lifecycle history. It provides the audit trail for subscription
/// metrics now and future entitlement/payment integrations later.
model SubscriptionEvent {
  id             String                @id
  subscriptionId String                @map("subscription_id")
  type           SubscriptionEventType
  actorUserId    String?               @map("actor_user_id")
  details        Json?
  occurredAt     Int                   @map("occurred_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, occurredAt], name: "billing_subscription_events_subscription_id_occurred_at_idx")
  @@map("billing_subscription_events")
}
