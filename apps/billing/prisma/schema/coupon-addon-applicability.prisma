
model CouponAddonApplicability {
  id        String @id
  tenantId  String @map("tenant_id")
  couponId  String @map("coupon_id")
  addonId   String @map("addon_id")
  createdAt Int    @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_coupon_addon_applicabilities_tenant_fkey")
  coupon Coupon @relation(fields: [tenantId, couponId], references: [tenantId, id], onDelete: Cascade, onUpdate: Cascade, map: "billing_coupon_addon_applicabilities_coupon_fkey")
  addon  Addon  @relation(fields: [addonId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_coupon_addon_applicabilities_addon_fkey")

  @@unique([tenantId, couponId, addonId], name: "billing_coupon_addon_applicability_key", map: "billing_coupon_addon_applicability_key")
  @@index([couponId], map: "billing_coupon_addon_applicability_coupon_idx")
  @@index([addonId], map: "billing_coupon_addon_applicability_addon_idx")
  @@map("billing_coupon_addon_applicabilities")
}
