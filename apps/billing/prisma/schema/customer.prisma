/// A party billed by a tenant. Core user and organization identifiers
/// are optional opaque references; an external customer has neither reference.
/// For core-linked customers the identity fields (name, email, companyName)
/// are a cached snapshot of the live 876 record — resolved live on the detail
/// view and refreshed opportunistically (see `coreSyncedAt`).
model Customer {
  id                          String         @id
  tenantId                    String         @map("tenant_id")
  customerType                CustomerType   @default(EXTERNAL) @map("customer_type")
  customerKind                CustomerKind   @default(INDIVIDUAL) @map("customer_kind")
  organizationId              String?        @map("organization_id")
  userId                      String?        @map("user_id")
  externalReference           String?        @map("external_reference")
  sourceAppId                 String?        @map("source_app_id")
  sourceExternalReference     String?        @map("source_external_reference")
  sourceIdempotencyKey        String?        @map("source_idempotency_key")
  sourcePayloadHash           String?        @map("source_payload_hash")
  /// Display name — the canonical label shown across the UI.
  name                        String
  salutation                  String?
  firstName                   String?        @map("first_name")
  lastName                    String?        @map("last_name")
  companyName                 String?        @map("company_name")
  email                       String?
  /// Primary/mobile phone.
  phone                       String?
  workPhone                   String?        @map("work_phone")
  /// Legacy freeform billing address JSON. Retained for back-compat; new writes
  /// go to the `billing_addresses` table via the `addresses` relation.
  billingAddress              Json?          @map("billing_address")
  metadata                    Json?
  defaultCurrency             String?        @map("default_currency")
  language                    String?        @map("language")
  paymentTermId               String?        @map("payment_term_id")
  salespersonId               String?        @map("salesperson_id")
  priceListId                 String?        @map("price_list_id")
  consolidatedBillingOverride Boolean?       @map("consolidated_billing_override")
  taxBehaviorOverride         TaxBehavior?   @map("tax_behavior_override")
  lateFeeExempt               Boolean        @default(false) @map("late_fee_exempt")
  invoiceNotes                String?        @map("invoice_notes")
  invoiceTerms                String?        @map("invoice_terms")
  /// Denormalized AR position, in the customer currency's minor units.
  /// outstandingReceivable = sum of open invoice balances; unusedCredits =
  /// unapplied payments + open credit-note balances available to apply.
  outstandingReceivable       BigInt         @default(0) @map("outstanding_receivable")
  unusedCredits               BigInt         @default(0) @map("unused_credits")
  /// Unix seconds of the last successful snapshot refresh from the live 876
  /// record. Null for external (non-876) customers.
  coreSyncedAt                Int?           @map("core_synced_at")
  status                      CustomerStatus @default(ACTIVE)
  createdAt                   Int            @map("created_at")
  updatedAt                   Int            @map("updated_at")

  tenant              Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  languageRecord      Language?                   @relation("CustomerLanguage", fields: [language], references: [code], onDelete: SetNull)
  paymentTerm         PaymentTerm?                @relation(fields: [tenantId, paymentTermId], references: [tenantId, id], onDelete: Restrict)
  salesperson         Salesperson?                @relation(fields: [tenantId, salespersonId], references: [tenantId, id], onDelete: Restrict)
  priceList           PriceList?                  @relation(fields: [tenantId, priceListId], references: [tenantId, id], onDelete: Restrict)
  contacts            Contact[]
  addresses           Address[]
  quotes              Quote[]
  estimates           Estimate[]
  invoices            Invoice[]
  payments            Payment[]
  creditNotes         CreditNote[]
  refunds             Refund[]
  subscriptions       Subscription[]
  subscriptionCharges SubscriptionCharge[]
  promotionCodes      PromotionCode[]
  couponEligibilities CouponCustomerEligibility[]
  couponRedemptions   CouponRedemption[]
  ledgerEntries       CustomerLedgerEntry[]
  paymentAttempts     PaymentAttempt[]

  @@unique([tenantId, id])
  @@unique([tenantId, organizationId], name: "billing_customers_tenant_id_organization_id_key")
  @@unique([tenantId, userId], name: "billing_customers_tenant_id_user_id_key")
  @@unique([tenantId, externalReference], name: "billing_customers_tenant_id_external_reference_key")
  @@unique([tenantId, sourceAppId, sourceExternalReference], name: "billing_customers_source_external_key")
  @@unique([tenantId, sourceAppId, sourceIdempotencyKey], name: "billing_customers_source_idempotency_key")
  @@index([tenantId], name: "billing_customers_tenant_id_idx")
  @@index([tenantId, sourceAppId], name: "billing_customers_source_app_idx")
  @@index([priceListId], name: "billing_customers_price_list_id_idx")
  @@index([externalReference], name: "billing_customers_external_reference_idx")
  @@map("billing_customers")
}

/// A contact person attached to a customer. For an external customer these are
/// hand-entered people; for a core 876 organization the owner is seeded as the
/// default primary contact (members are never bulk-imported). `userId` is an
/// optional opaque 876 user reference — no cross-DB foreign key.
model Contact {
  id           String  @id
  tenantId     String  @map("tenant_id")
  customerId   String  @map("customer_id")
  userId       String? @map("user_id")
  salutation   String?
  firstName    String? @map("first_name")
  lastName     String? @map("last_name")
  email        String?
  workPhone    String? @map("work_phone")
  mobilePhone  String? @map("mobile_phone")
  isPrimary    Boolean @default(false) @map("is_primary")
  /// Unix seconds of the last snapshot refresh for a core-linked contact.
  coreSyncedAt Int?    @map("core_synced_at")
  createdAt    Int     @map("created_at")
  updatedAt    Int     @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [tenantId, customerId], references: [tenantId, id], onDelete: Cascade)

  @@unique([tenantId, id])
  @@index([tenantId, customerId], name: "billing_contacts_tenant_customer_idx")
  @@map("billing_contacts")
}

/// A physical address attached to a customer. Modeled on the platform
/// `addresses` table but cross-DB-safe: `state` (parish/region) and
/// `countryCode` are opaque strings, never foreign keys into the identity DB.
/// Latitude/longitude are optional and used only to place the address on a map.
model Address {
  id          String  @id
  tenantId    String  @map("tenant_id")
  customerId  String  @map("customer_id")
  type        String  @default("billing")
  label       String?
  attention   String?
  line1       String?
  line2       String?
  city        String?
  state       String?
  postalCode  String? @map("postal_code")
  countryCode String? @map("country_code")
  latitude    Float?
  longitude   Float?
  isDefault   Boolean @default(false) @map("is_default")
  createdAt   Int     @map("created_at")
  updatedAt   Int     @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [tenantId, customerId], references: [tenantId, id], onDelete: Cascade)

  @@unique([tenantId, id])
  @@index([tenantId, customerId], name: "billing_addresses_tenant_customer_idx")
  @@map("billing_addresses")
}
