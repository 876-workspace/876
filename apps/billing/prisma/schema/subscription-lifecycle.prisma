/// A requested subscription composition or commercial-term change. Desired
/// items are normalized below so scheduled changes remain queryable.
model SubscriptionAmendment {
  id                       String                             @id
  tenantId                 String                             @map("tenant_id")
  subscriptionId           String                             @map("subscription_id")
  timing                   SubscriptionChangeTiming           @default(IMMEDIATE)
  effectiveAt              Int                                @map("effective_at")
  status                   SubscriptionAmendmentStatus        @default(PENDING)
  prorationBehavior        ProrationBehavior                  @default(CREATE_PRORATIONS) @map("proration_behavior")
  paymentFailureBehavior   SubscriptionPaymentFailureBehavior @default(PREVENT_CHANGE) @map("payment_failure_behavior")
  collectionMethod         CollectionMethod?                  @map("collection_method")
  billingTiming            BillingTiming?                     @map("billing_timing")
  paymentTermId            String?                            @map("payment_term_id")
  taxBehavior              TaxBehavior?                       @map("tax_behavior")
  invoiceModeOverride      SubscriptionInvoiceMode?           @map("invoice_mode_override")
  renewalPricingPolicy     RenewalPricingPolicy?              @map("renewal_pricing_policy")
  renewalAdjustmentPercent Decimal?                           @map("renewal_adjustment_percent") @db.Decimal(7, 4)
  billingCycleAnchor       Int?                               @map("billing_cycle_anchor")
  remainingCycles          Int?                               @map("remaining_cycles")
  requestedByUserId        String?                            @map("requested_by_user_id")
  reason                   String?
  appliedAt                Int?                               @map("applied_at")
  canceledAt               Int?                               @map("canceled_at")
  failureCode              String?                            @map("failure_code")
  failureMessage           String?                            @map("failure_message")
  createdAt                Int                                @map("created_at")
  updatedAt                Int                                @map("updated_at")

  tenant       Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription                @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  paymentTerm  PaymentTerm?                @relation(fields: [tenantId, paymentTermId], references: [tenantId, id], onDelete: Restrict)
  items        SubscriptionAmendmentItem[]

  @@unique([tenantId, id])
  @@index([subscriptionId, status, effectiveAt], name: "billing_subscription_amendments_schedule_idx")
  @@index([tenantId, status, effectiveAt], name: "billing_subscription_amendments_tenant_schedule_idx")
  @@map("billing_subscription_amendments")
}

model SubscriptionAmendmentItem {
  id          String  @id
  amendmentId String  @map("amendment_id")
  priceId     String  @map("price_id")
  position    Int     @default(0)
  quantity    Int     @default(1)
  unitAmount  BigInt? @map("unit_amount")
  currency    String? @db.Char(3)
  description String?
  createdAt   Int     @map("created_at")

  amendment SubscriptionAmendment @relation(fields: [amendmentId], references: [id], onDelete: Cascade)
  price     Price                 @relation(fields: [priceId], references: [id], onDelete: Restrict)

  @@unique([amendmentId, position], name: "billing_subscription_amendment_items_position_key")
  @@index([priceId], name: "billing_subscription_amendment_items_price_idx")
  @@map("billing_subscription_amendment_items")
}

model SubscriptionLifecycleSchedule {
  id                    String                       @id
  tenantId              String                       @map("tenant_id")
  subscriptionId        String                       @map("subscription_id")
  action                SubscriptionLifecycleAction
  effectiveAt           Int                          @map("effective_at")
  status                SubscriptionScheduleStatus   @default(SCHEDULED)
  resumeAt              Int?                         @map("resume_at")
  pauseUnbilledBehavior PauseUnbilledChargeBehavior? @map("pause_unbilled_behavior")
  pauseCreditBehavior   PauseCreditBehavior?         @map("pause_credit_behavior")
  resumeBillingBehavior ResumeBillingBehavior?       @map("resume_billing_behavior")
  reasonCode            String?                      @map("reason_code")
  reason                String?
  feedback              String?
  requestedByUserId     String?                      @map("requested_by_user_id")
  appliedAt             Int?                         @map("applied_at")
  canceledAt            Int?                         @map("canceled_at")
  failureMessage        String?                      @map("failure_message")
  createdAt             Int                          @map("created_at")
  updatedAt             Int                          @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@unique([tenantId, id])
  @@index([subscriptionId, status, effectiveAt], name: "billing_subscription_schedules_subscription_idx")
  @@index([tenantId, status, effectiveAt], name: "billing_subscription_schedules_tenant_idx")
  @@map("billing_subscription_lifecycle_schedules")
}

model SubscriptionCharge {
  id              String                            @id
  tenantId        String                            @map("tenant_id")
  subscriptionId  String                            @map("subscription_id")
  customerId      String                            @map("customer_id")
  addonId         String?                           @map("addon_id")
  priceId         String?                           @map("price_id")
  invoiceId       String?                           @map("invoice_id")
  status          SubscriptionChargeStatus          @default(UNBILLED)
  invoiceBehavior SubscriptionChargeInvoiceBehavior @default(INVOICE_IMMEDIATELY) @map("invoice_behavior")
  description     String
  quantity        Int                               @default(1)
  unitAmount      BigInt                            @map("unit_amount")
  currency        String                            @db.Char(3)
  taxBehavior     TaxBehavior                       @default(EXCLUSIVE) @map("tax_behavior")
  isTaxable       Boolean                           @default(true) @map("is_taxable")
  serviceAt       Int?                              @map("service_at")
  createdByUserId String?                           @map("created_by_user_id")
  invoicedAt      Int?                              @map("invoiced_at")
  voidedAt        Int?                              @map("voided_at")
  createdAt       Int                               @map("created_at")
  updatedAt       Int                               @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  addon        Addon?        @relation(fields: [addonId], references: [id], onDelete: Restrict)
  price        Price?        @relation(fields: [priceId], references: [id], onDelete: Restrict)
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  invoiceLines InvoiceLine[]

  @@unique([tenantId, id])
  @@index([subscriptionId, status, createdAt], name: "billing_subscription_charges_subscription_idx")
  @@index([customerId, status], name: "billing_subscription_charges_customer_idx")
  @@index([invoiceId], name: "billing_subscription_charges_invoice_idx")
  @@map("billing_subscription_charges")
}

/// Durable staff-notification outbox. Delivery adapters claim these rows and
/// record attempts without coupling invoice transactions to email providers.
model SubscriptionNotificationOutbox {
  id             String                         @id
  tenantId       String                         @map("tenant_id")
  subscriptionId String?                        @map("subscription_id")
  invoiceId      String?                        @map("invoice_id")
  type           SubscriptionNotificationType
  status         SubscriptionNotificationStatus @default(PENDING)
  dedupeKey      String                         @map("dedupe_key")
  payload        Json?
  attemptCount   Int                            @default(0) @map("attempt_count")
  lastAttemptAt  Int?                           @map("last_attempt_at")
  deliveredAt    Int?                           @map("delivered_at")
  failureMessage String?                        @map("failure_message")
  createdAt      Int                            @map("created_at")
  updatedAt      Int                            @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@unique([tenantId, dedupeKey], name: "billing_subscription_notifications_dedupe_key")
  @@index([tenantId, status, createdAt], name: "billing_subscription_notifications_delivery_idx")
  @@index([subscriptionId, createdAt], name: "billing_subscription_notifications_subscription_idx")
  @@map("billing_subscription_notification_outbox")
}

/// Join evidence allows a consolidated invoice to cover multiple agreements
/// without overloading Invoice.subscriptionId.
model InvoiceSubscription {
  tenantId           String @map("tenant_id")
  invoiceId          String @map("invoice_id")
  subscriptionId     String @map("subscription_id")
  servicePeriodStart Int?   @map("service_period_start")
  servicePeriodEnd   Int?   @map("service_period_end")
  subtotalAmount     BigInt @default(0) @map("subtotal_amount")
  discountAmount     BigInt @default(0) @map("discount_amount")
  taxAmount          BigInt @default(0) @map("tax_amount")
  totalAmount        BigInt @default(0) @map("total_amount")
  createdAt          Int    @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@id([invoiceId, subscriptionId])
  @@index([tenantId, subscriptionId], name: "billing_invoice_subscriptions_tenant_subscription_idx")
  @@map("billing_invoice_subscriptions")
}

model SubscriptionCustomView {
  id            String               @id
  tenantId      String               @map("tenant_id")
  name          String
  ownerUserId   String?              @map("owner_user_id")
  visibility    CustomViewVisibility @default(PRIVATE)
  isFavorite    Boolean              @default(false) @map("is_favorite")
  sortField     String?              @map("sort_field")
  sortDirection String?              @map("sort_direction")
  createdAt     Int                  @map("created_at")
  updatedAt     Int                  @map("updated_at")

  tenant  Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rules   SubscriptionCustomViewRule[]
  columns SubscriptionCustomViewColumn[]

  @@unique([tenantId, id])
  @@unique([tenantId, ownerUserId, name], name: "billing_subscription_views_owner_name_key")
  @@index([tenantId, visibility, isFavorite], name: "billing_subscription_views_visibility_idx")
  @@map("billing_subscription_custom_views")
}

model SubscriptionCustomViewRule {
  id       String                 @id
  viewId   String                 @map("view_id")
  position Int                    @default(0)
  field    String
  operator CustomViewRuleOperator
  value    String?

  view SubscriptionCustomView @relation(fields: [viewId], references: [id], onDelete: Cascade)

  @@unique([viewId, position], name: "billing_subscription_view_rules_position_key")
  @@map("billing_subscription_custom_view_rules")
}

model SubscriptionCustomViewColumn {
  id       String @id
  viewId   String @map("view_id")
  position Int    @default(0)
  field    String

  view SubscriptionCustomView @relation(fields: [viewId], references: [id], onDelete: Cascade)

  @@unique([viewId, position], name: "billing_subscription_view_columns_position_key")
  @@map("billing_subscription_custom_view_columns")
}
