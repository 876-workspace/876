/// A modular product enhancement. Monetary terms live on immutable prices so
/// catalog changes never rewrite an existing subscription agreement.
model Addon {
  id                    String        @id
  tenantId              String        @map("tenant_id")
  productId             String        @map("product_id")
  code                  String
  name                  String
  description           String?
  imageUrl              String?       @map("image_url")
  type                  ItemType      @default(SERVICE)
  priceType             PriceType     @default(RECURRING) @map("price_type")
  intervalUnit          IntervalUnit? @map("interval_unit")
  intervalCount         Int?          @map("interval_count")
  unitName              String?       @map("unit_name")
  taxCode               String?       @map("tax_code")
  isTaxable             Boolean       @default(false) @map("is_taxable")
  showInCheckout        Boolean       @default(true) @map("show_in_checkout")
  allowPortalManagement Boolean       @default(false) @map("allow_portal_management")
  isActive              Boolean       @default(true) @map("is_active")
  metadata              Json?
  createdAt             Int           @map("created_at")
  updatedAt             Int           @map("updated_at")

  tenant                Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product               Product                    @relation(fields: [productId], references: [id], onDelete: Restrict)
  prices                Price[]
  planAssociations      PlanAddonAssociation[]
  couponApplicabilities CouponAddonApplicability[]
  subscriptionCharges   SubscriptionCharge[]

  @@unique([tenantId, code], name: "billing_addons_tenant_code_key")
  @@index([tenantId, isActive], name: "billing_addons_tenant_active_idx")
  @@index([productId], name: "billing_addons_product_idx")
  @@map("billing_addons")
}

/// Availability and automation rules between a plan and an add-on.
model PlanAddonAssociation {
  id              String                    @id
  tenantId        String                    @map("tenant_id")
  planId          String                    @map("plan_id")
  addonId         String                    @map("addon_id")
  associationType AddonAssociationType      @default(OPTIONAL) @map("association_type")
  events          AddonAssociationEvent[]   @default([SUBSCRIPTION_ACTIVATION])
  frequency       AddonAssociationFrequency @default(EVERY_OCCURRENCE)
  isActive        Boolean                   @default(true) @map("is_active")
  createdAt       Int                       @map("created_at")
  updatedAt       Int                       @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  addon  Addon  @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@unique([tenantId, planId, addonId], name: "billing_plan_addon_associations_key")
  @@index([planId, isActive], name: "billing_plan_addon_associations_plan_idx")
  @@index([addonId, isActive], name: "billing_plan_addon_associations_addon_idx")
  @@map("billing_plan_addon_associations")
}
