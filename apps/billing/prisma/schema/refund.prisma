/// Cash returned to a customer, drawn from an overpayment (a Payment's
/// unapplied amount) or a CreditNote balance. Recording a refund reduces the
/// source credit; the money leaves a deposit account. A refund is distinct from
/// a credit note — the credit note documents the reduction, the refund moves
/// the cash.
model Refund {
  id               String  @id
  tenantId         String  @map("tenant_id")
  customerId       String  @map("customer_id")
  creditNoteId     String? @map("credit_note_id")
  paymentId        String? @map("payment_id")
  paymentModeId    String? @map("payment_mode_id")
  depositAccountId String? @map("deposit_account_id")
  number           String
  amount           BigInt
  currency         String  @db.Char(3)
  reason           String?
  notes            String? @db.Text
  refundedAt       Int     @map("refunded_at")
  createdAt        Int     @map("created_at")
  updatedAt        Int     @map("updated_at")

  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_refunds_tenant_id_fkey")
  customer       Customer              @relation(fields: [tenantId, customerId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_refunds_customer_fkey")
  creditNote     CreditNote?           @relation(fields: [creditNoteId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "billing_refunds_credit_note_fkey")
  payment        Payment?              @relation(fields: [paymentId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "billing_refunds_payment_fkey")
  paymentMode    PaymentMode?          @relation(fields: [tenantId, paymentModeId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_refunds_payment_mode_fkey")
  depositAccount BankAccount?          @relation(fields: [tenantId, depositAccountId], references: [tenantId, id], onDelete: Restrict, onUpdate: Cascade, map: "billing_refunds_deposit_account_fkey")
  ledgerEntries  CustomerLedgerEntry[]

  @@unique([tenantId, id], map: "billing_refunds_tenant_id_id_key")
  @@unique([tenantId, number], name: "billing_refunds_tenant_id_number_key", map: "billing_refunds_tenant_id_number_key")
  @@index([tenantId, customerId], map: "billing_refunds_tenant_customer_idx")
  @@index([tenantId, creditNoteId], map: "billing_refunds_tenant_credit_note_idx")
  @@index([tenantId, paymentId], map: "billing_refunds_tenant_payment_idx")
  @@index([creditNoteId], map: "billing_refunds_credit_note_id_idx")
  @@index([customerId], map: "billing_refunds_customer_id_idx")
  @@index([depositAccountId], map: "billing_refunds_deposit_account_id_idx")
  @@index([paymentId], map: "billing_refunds_payment_id_idx")
  @@index([paymentModeId], map: "billing_refunds_payment_mode_id_idx")
  @@map("billing_refunds")
}
