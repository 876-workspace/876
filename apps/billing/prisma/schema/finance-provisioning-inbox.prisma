/// Durable receipt for one Core finance provisioning event. Receipts are not
/// foreign-keyed to mutable tenant data so an event remains auditable even if
/// its connection is later revoked or removed under a retention policy.
model FinanceProvisioningInbox {
  eventId             String  @id @map("event_id")
  eventType           String  @map("event_type")
  contractVersion     Int     @map("contract_version")
  payloadHash         String  @map("payload_hash")
  aggregateId         String  @map("aggregate_id")
  organizationId      String  @map("organization_id")
  sourceAppId         String  @map("source_app_id")
  connectionId        String  @map("connection_id")
  provisioningVersion Int     @map("provisioning_version")
  lifecycleVersion    Int     @map("lifecycle_version")
  applied             Boolean
  processedAt         Int     @map("processed_at")
  createdAt           Int     @map("created_at")

  @@index([aggregateId, lifecycleVersion], map: "billing_finance_inbox_aggregate_version_idx")
  @@index([organizationId, sourceAppId], map: "billing_finance_inbox_org_app_idx")
  @@map("billing_finance_provisioning_inbox")
}
