/// A tenant-owned financial account used to track manual money movement.
/// One account has exactly one currency; cross-currency conversion is outside
/// this foundation.
model BankAccount {
  id          String          @id
  tenantId    String          @map("tenant_id")
  name        String          @db.VarChar(120)
  accountType BankAccountType @map("account_type")
  currency    String          @db.Char(3)
  description String?         @db.Text
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   Int             @map("created_at")
  updatedAt   Int             @map("updated_at")

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions BankTransaction[]
  payments     Payment[]
  refunds      Refund[]

  @@unique([tenantId, id])
  @@unique([tenantId, name])
  @@index([tenantId, isActive], name: "billing_bank_accounts_tenant_id_is_active_idx")
  @@map("billing_bank_accounts")
}

/// A credit or debit recorded against a financial account. Payment-generated
/// credits keep a direct one-to-one link to their source payment.
model BankTransaction {
  id          String                @id
  tenantId    String                @map("tenant_id")
  accountId   String                @map("account_id")
  paymentId   String?               @map("payment_id")
  type        BankTransactionType
  amount      BigInt
  date        Int
  description String?               @db.Text
  status      BankTransactionStatus @default(UNCATEGORIZED)
  reference   String?               @db.VarChar(120)
  createdAt   Int                   @map("created_at")
  updatedAt   Int                   @map("updated_at")

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account BankAccount @relation(fields: [tenantId, accountId], references: [tenantId, id], onDelete: Cascade)
  payment Payment?    @relation(fields: [tenantId, paymentId], references: [tenantId, id], onDelete: Cascade)

  @@unique([tenantId, paymentId])
  @@index([tenantId, accountId, date], name: "billing_bank_transactions_tenant_account_date_idx")
  @@index([tenantId, date], name: "billing_bank_transactions_tenant_id_date_idx")
  @@map("billing_bank_transactions")
}
