/// A tenant-owned financial account used to track manual money movement.
/// One account has exactly one currency; cross-currency conversion is outside
/// this foundation.
model BankAccount {
  id          String          @id
  tenantId    String          @map("tenant_id")
  name        String          @db.VarChar(120)
  accountType BankAccountType @map("account_type")
  currency    String          @db.Char(3)
  description String?         @db.Text
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   Int             @map("created_at")
  updatedAt   Int             @map("updated_at")

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "billing_bank_accounts_tenant_id_fkey")
  transactions BankTransaction[]
  payments     Payment[]
  refunds      Refund[]

  @@unique([tenantId, id], map: "billing_bank_accounts_tenant_id_id_key")
  @@unique([tenantId, name], map: "billing_bank_accounts_tenant_id_name_key")
  @@index([tenantId, isActive], map: "billing_bank_accounts_tenant_id_is_active_idx")
  @@map("billing_bank_accounts")
}
