# Local development defaults for @876/api (non-secret).
# Secrets (WORKOS_API_KEY, WORKOS_CLIENT_ID, DATABASE_URL, ...) go in .env — see .env.example.
PORT=4000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
# Empty → API derives `{x-876-origin}/callback` per app (embedded auth).
NEXT_PUBLIC_WORKOS_REDIRECT_URI=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
