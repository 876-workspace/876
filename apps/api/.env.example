# FastAPI API (@876/api) — runs on PORT, owns the database + WorkOS server client.
PORT=4000

# WorkOS server credentials (API-only — never in Next.js apps).
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# Access-token verification (JWKS). Leave blank to use WorkOS default for the client id.
WORKOS_JWKS_URL=

# Configure stable RS256 OAuth signing keys in every environment.
OAUTH_PRIVATE_KEY=
OAUTH_KEY_ID=876-local

# Shared secret for trusted server-to-server calls (AdminDep). Must match
# API_INTERNAL_KEY in both Next.js apps.
API_INTERNAL_KEY=

# PostgreSQL connection string.
DATABASE_URL=

# Comma-separated browser origins allowed to call the API.
# On GitHub Codespaces, setup-env.mjs writes .env.development.local with
# the forwarded-port URLs — no need to set this manually there.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# PostHog feature-flag management. The personal key stays server-side.
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=0
POSTHOG_HOST=https://us.i.posthog.com

# Observability.
SENTRY_DSN=
LOG_LEVEL=info
ENVIRONMENT=development

# Set to true when running behind HTTPS in development (e.g. Gitpod, Codespaces).
# Browsers silently drop non-Secure cookies over HTTPS, breaking session persistence.
# Defaults to IS_PRODUCTION when unset.
COOKIE_SECURE=

# The account with this email is bootstrapped as the platform owner (leave empty to disable).
PLATFORM_OWNER_EMAIL=

# Billing service origin used by first-party app seeding and finance delivery.
BILLING_URL=http://localhost:3004
# Shared service credential used only for the durable Core-to-Billing finance
# provisioning outbox. It must match Billing's BILLING_INTERNAL_KEY.
BILLING_INTERNAL_KEY=
FINANCE_PROVISIONING_POLL_SECONDS=30
FINANCE_PROVISIONING_BATCH_SIZE=25
