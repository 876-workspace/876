{
  "name": "@876/widgets-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prisma generate && next dev --turbopack --port 3005",
    "build": "next build",
    "start": "next start -H :: --port ${PORT:-3005}",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf .next .turbo",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@876/core": "workspace:*",
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "next": "16.2.6",
    "pg": "8.13.1",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@types/pg": "8.11.10",
    "dotenv": "16.4.7",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "prisma": "7.7.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
