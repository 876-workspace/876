# Copy these values to apps/widgets-api/.env. Never commit real credentials.
# Widgets Postgres (Neon) is only available to widgets-api (Notepad, etc.).
WIDGETS_DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Generate one long random secret and copy it to each widget host's .env.
WIDGETS_SERVICE_KEY="replace-with-long-random-secret"

# Knowledge Base Convex deployment (KB tables only — no Notepad).
# From apps/widgets-api: npx convex dev  (writes CONVEX_URL into .env.local)
CONVEX_URL="https://YOUR_DEPLOYMENT.convex.cloud"
# Optional: deploy key for CI / server-side ConvexHttpClient admin
# CONVEX_DEPLOY_KEY=""
