PORT=4004
BILLING_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/billing
# Optional legacy source database used only by the reconciliation command.
BILLING_LEGACY_DATABASE_URL=
# Exactly one backend may own mutations: legacy, fastapi, or none (freeze).
BILLING_WRITER=fastapi
API_URL=http://127.0.0.1:4000
CORS_ALLOWED_ORIGINS=http://localhost:3004
ENVIRONMENT=development
LOG_LEVEL=info
SENTRY_DSN=
