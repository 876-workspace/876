{
  "name": "@876/billing-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": ".venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 4004 --reload",
    "build": "[ -x .venv/bin/python ] && .venv/bin/python -m compileall -q . || echo 'skip billing api build (no venv)'",
    "start": ".venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port ${PORT:-4004}",
    "typecheck": ".venv/bin/python -m mypy --explicit-package-bases api core db domains migrations scripts/check_cutover.py scripts/check_environment.py scripts/check_migration.py scripts/reconcile_databases.py scripts/run_billing.py main.py",
    "test": ".venv/bin/python -m pytest",
    "lint": ".venv/bin/python -m ruff check .",
    "format": ".venv/bin/python -m ruff format .",
    "format:check": ".venv/bin/python -m ruff format --check .",
    "db:migrate": ".venv/bin/python -m alembic upgrade head",
    "db:migration:check": ".venv/bin/python -m scripts.check_migration",
    "db:reconcile": ".venv/bin/python -m scripts.reconcile_databases",
    "env:check": ".venv/bin/python -m scripts.check_environment",
    "cutover:check": ".venv/bin/python -m scripts.check_cutover",
    "billing:run": ".venv/bin/python -m scripts.run_billing",
    "db:models:generate": ".venv/bin/python scripts/generate_models.py generate",
    "db:models:check": ".venv/bin/python scripts/generate_models.py check",
    "api:routes:generate": ".venv/bin/python scripts/generate_routes.py generate",
    "api:routes:check": ".venv/bin/python scripts/generate_routes.py check",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@cloudflare/containers": "0.3.7"
  },
  "devDependencies": {
    "wrangler": "4.113.0",
    "typescript": "5.9.3",
    "@types/node": "25.6.2"
  }
}
