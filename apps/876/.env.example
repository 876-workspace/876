# ─── Server-side (never exposed to the browser) ──────────────────────────────

# Base URL for server-side API calls.
API_URL=https://876-api.vercel.app

# Server log level for Next.js server logs.
LOG_LEVEL=info

# Shared secret for trusted server-to-server calls to the API. Must match
# API_INTERNAL_KEY set on the API deployment.
API_INTERNAL_KEY=

# Seals/unseals the iron-session cookie. Must be 32+ characters.
# Must be the same value as WORKOS_COOKIE_PASSWORD in Console.
WORKOS_COOKIE_PASSWORD=

# Optional: override the session cookie name (default: 876-session).
# SESSION_COOKIE_NAME=876-session

# App API key for the 876-app registered app (format: 876_app_secret_...). Attached
# server-side by the /api/auth proxy; never sent to the browser. Run
# apps/api/scripts/seed_internal.py to generate one for local dev.
API_876_KEY=

# ─── Public (exposed to the browser via NEXT_PUBLIC_*) ───────────────────────

# Canonical URL of this app.
NEXT_PUBLIC_APP_URL=https://876-app.vercel.app
NEXT_PUBLIC_SITE_URL=https://876-app.vercel.app

# URL of the Console app (used for cross-app links).
NEXT_PUBLIC_CONSOLE_URL=https://876-misc.vercel.app

# Observability.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_APP_VERSION=
NEXT_PUBLIC_APP_ENVIRONMENT=production

# Core 876 app slug for this app (public; defaults to the canonical slug in code).
NEXT_PUBLIC_876_APP_SLUG=876-consumer
