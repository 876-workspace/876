{
  "name": "@876/sdk",
  "version": "0.1.0",
  "description": "Request-only JavaScript SDK for 876 authentication.",
  "license": "UNLICENSED",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./oauth": {
      "types": "./src/oauth.ts",
      "default": "./src/oauth.ts"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "default": "./src/errors.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node --eval \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "pnpm clean",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "publint": "publint",
    "attw": "attw --pack .",
    "pack:check": "npm pack --dry-run",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm publint && pnpm attw && pnpm pack:check",
    "version:patch": "pnpm version patch",
    "version:minor": "pnpm version minor",
    "version:major": "pnpm version major",
    "prepublishOnly": "pnpm check"
  },
  "dependencies": {
    "@876/core": "workspace:*",
    "@876/types": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "publint": "0.3.21",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
