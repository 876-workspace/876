{
  "name": "@876/billing",
  "version": "0.1.0",
  "description": "Typed clients for the 876 Billing service.",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./admin": {
      "types": "./src/admin/index.ts",
      "default": "./src/admin/index.ts"
    },
    "./integration": {
      "types": "./src/integration/index.ts",
      "default": "./src/integration/index.ts"
    },
    "./proxy": {
      "types": "./src/proxy.ts",
      "default": "./src/proxy.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "@876/core": "workspace:*",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
