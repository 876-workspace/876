{
  "name": "@876/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./countries.json": {
      "default": "./src/countries.json"
    },
    "./errors": {
      "types": "./src/lib/errors/index.ts",
      "default": "./src/lib/errors/index.ts"
    },
    "./errors/*": {
      "types": "./src/lib/errors/*.ts",
      "default": "./src/lib/errors/*.ts"
    },
    "./id": {
      "types": "./src/lib/id/index.ts",
      "default": "./src/lib/id/index.ts"
    },
    "./timestamps": {
      "types": "./src/lib/timestamps.ts",
      "default": "./src/lib/timestamps.ts"
    },
    "./platform-apps": {
      "types": "./src/lib/platform-apps.ts",
      "default": "./src/lib/platform-apps.ts"
    },
    "./utils": {
      "types": "./src/utils.ts",
      "default": "./src/utils.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "default": "./src/types/*.ts"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    },
    "./platform": {
      "types": "./src/platform/index.ts",
      "default": "./src/platform/index.ts"
    },
    "./client/lookup": {
      "types": "./src/client/lookup.ts",
      "default": "./src/client/lookup.ts"
    },
    "./fetch/bridge": {
      "types": "./src/fetch/bridge.ts",
      "default": "./src/fetch/bridge.ts"
    },
    "./api": {
      "types": "./src/api.ts",
      "default": "./src/api.ts"
    },
    "./auth/*": {
      "types": "./src/auth/*.ts",
      "default": "./src/auth/*.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "server-only": "0.0.1",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
