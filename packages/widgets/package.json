{
  "name": "@876/widgets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./server/admin": {
      "types": "./src/server/admin.ts",
      "default": "./src/server/admin.ts"
    },
    "./browser": {
      "types": "./src/browser/notes.ts",
      "default": "./src/browser/notes.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "@876/core": "workspace:*",
    "@876/ui": "workspace:*",
    "@editorjs/checklist": "1.6.0",
    "@editorjs/editorjs": "2.31.6",
    "@editorjs/header": "2.8.9",
    "@editorjs/list": "2.0.9",
    "@editorjs/underline": "1.2.1",
    "motion": "12.40.0",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@edge-runtime/vm": "5.0.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@vitest/browser-playwright": "4.1.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "jsdom": "29.1.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "typescript": "5.9.3",
    "vitest": "4.1.5",
    "vitest-browser-react": "2.2.0"
  }
}
