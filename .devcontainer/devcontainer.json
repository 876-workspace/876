{
  "name": "876 Platform",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",

  "postCreateCommand": "apt-get update && apt-get install -y bubblewrap ripgrep && ln -sf /usr/bin/bwrap /usr/local/bin/bubblewrap && corepack enable && pnpm install",

  "postStartCommand": "node .devcontainer/setup-env.mjs && bash scripts/bootstrap-claude.sh && bash scripts/bootstrap-tools.sh",

  "forwardPorts": [3000, 3001, 3002, 3003, 3004, 3005, 4000, 4004],

  "portsAttributes": {
    "3000": {
      "label": "876",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "3001": {
      "label": "876 Enterprise",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "3002": {
      "label": "876 Console",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "3003": {
      "label": "876 Couriers",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "3004": {
      "label": "876 Billing",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "3005": {
      "label": "876 Widgets API",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "4000": {
      "label": "876 API",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "4004": {
      "label": "876 Billing API",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  }
}
